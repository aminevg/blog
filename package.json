{
  "name": "blog",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "format": "prettier --experimental-cli --write .",
    "format:check": "prettier --experimental-cli --check .",
    "format:file": "prettier --write",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:file": "eslint --fix",
    "textlint": "textlint \"src/content/**/*.{md,mdx}\"",
    "textlint:fix": "textlint --fix \"src/content/**/*.{md,mdx}\"",
    "textlint:file": "textlint --fix",
    "spell": "cspell \"**/*.{astro,ts,mjs,md,mdx,json,css}\"",
    "spell:file": "cspell",
    "verify": "npm run format:check && npm run lint && npm run textlint && npm run spell && npm run check"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.8",
    "astro-expressive-code": "^0.41.7",
    "astro-og-canvas": "^0.11.1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/node": "^24.0.0",
    "cspell": "^10.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-astro": "^1.7.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "textlint": "^15.5.4",
    "textlint-plugin-mdx": "^1.1.0",
    "textlint-rule-alex": "^5.0.0",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "textlint-rule-preset-smarthr": "^1.37.0",
    "textlint-rule-unexpanded-acronym": "^1.2.4",
    "textlint-rule-write-good": "^2.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.0",
    "wrangler": "^4.83.0"
  }
}
