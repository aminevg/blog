---
import "~/styles/global.css";
import { Font } from "astro:assets";
import type { Locale } from "~/config/site";
import Head from "~/components/layout/Head.astro";
import Masthead from "~/components/layout/Masthead.astro";
import Footer from "~/components/layout/Footer.astro";

export interface Props {
  locale: Locale;
  title: string;
  description: string;
  canonical?: string | URL;
  ogImage?: string | URL;
  alternateUrl?: string | null;
  xDefaultUrl?: string;
  article?: {
    publishedTime?: Date;
    modifiedTime?: Date;
  };
}

const {
  locale,
  title,
  description,
  canonical,
  ogImage,
  alternateUrl = null,
  xDefaultUrl,
  article,
} = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <Head
    locale={locale}
    title={title}
    description={description}
    canonical={canonical}
    ogImage={ogImage}
    alternateUrl={alternateUrl}
    xDefaultUrl={xDefaultUrl}
    article={article}
  >
    <Font cssVariable="--font-serif-web" preload />
    <Font cssVariable="--font-sans-web" preload />
    {locale === "ja" && <Font cssVariable="--font-serif-jp" preload />}
  </Head>
  <body
    class="accent-oxblood selection:bg-highlight selection:text-ink min-h-screen antialiased"
  >
    <a
      href="#main"
      class="bg-oxblood text-paper absolute top-0 -left-[9999px] z-[100] px-4 py-2 font-sans focus-visible:top-4 focus-visible:left-4"
      >Skip to content</a
    >
    <div class="px-page-x pt-page-y mx-auto max-w-[60rem] pb-12">
      <Masthead locale={locale} otherLocaleHref={alternateUrl} />
      <main id="main" class="min-h-[40vh]">
        <slot />
      </main>
      <Footer locale={locale} />
    </div>
  </body>
</html>
