---
import "~/styles/global.css";
import { Font } from "astro:assets";
import type { Locale } from "~/config/site";
import Head from "~/components/layout/Head.astro";
import Masthead from "~/components/layout/Masthead.astro";
import Footer from "~/components/layout/Footer.astro";

export interface Props {
  locale: Locale;
  title: string;
  description: string;
  canonical?: string | URL;
  ogImage?: string | URL;
  alternateUrl?: string | null;
  xDefaultUrl?: string;
  article?: {
    publishedTime?: Date;
    modifiedTime?: Date;
  };
}

const {
  locale,
  title,
  description,
  canonical,
  ogImage,
  alternateUrl = null,
  xDefaultUrl,
  article,
} = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <Head
    locale={locale}
    title={title}
    description={description}
    canonical={canonical}
    ogImage={ogImage}
    alternateUrl={alternateUrl}
    xDefaultUrl={xDefaultUrl}
    article={article}
  >
    <Font cssVariable="--font-serif-web" preload />
    <Font cssVariable="--font-sans-web" preload />
    {locale === "ja" && <Font cssVariable="--font-serif-jp" preload />}
  </Head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <div class="page">
      <Masthead locale={locale} otherLocaleHref={alternateUrl} />
      <main id="main" class="page__main">
        <slot />
      </main>
      <Footer locale={locale} />
    </div>
    <script is:inline>
      // Sidenote sync. On wide viewports (>= 62rem), the body is always
      // visible via CSS and the button is inert; reflect that in
      // aria-expanded so AT users aren't told "collapsed" while the note is
      // on screen. On narrow viewports, clicking the button toggles the
      // .is-open class on the surrounding .sidenote.
      (() => {
        const mql = window.matchMedia("(min-width: 62rem)");
        const syncAria = () => {
          const wide = mql.matches;
          document.querySelectorAll(".sidenote__ref").forEach((btn) => {
            if (wide) {
              btn.setAttribute("aria-expanded", "true");
              return;
            }
            const sn = btn.closest(".sidenote");
            const opened = sn?.classList.contains("is-open") ?? false;
            btn.setAttribute("aria-expanded", opened ? "true" : "false");
          });
        };
        const toggle = (e) => {
          if (mql.matches) return;
          const btn = e.target.closest(".sidenote__ref");
          if (!btn) return;
          const sn = btn.closest(".sidenote");
          if (!sn) return;
          sn.classList.toggle("is-open");
          btn.setAttribute(
            "aria-expanded",
            sn.classList.contains("is-open") ? "true" : "false",
          );
        };
        syncAria();
        mql.addEventListener("change", syncAria);
        document.addEventListener("click", toggle);
      })();
    </script>

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--color-accent);
        color: var(--color-bg);
        padding: 0.5rem 1rem;
        font-family: var(--font-sans);
        z-index: 100;
      }

      .skip-link:focus-visible {
        left: 1rem;
        top: 1rem;
      }

      .page {
        max-width: 60rem;
        margin: 0 auto;
        padding: clamp(2.5rem, 5vw, 4rem) clamp(1.25rem, 4vw, 2rem) 3rem;
      }

      .page__main {
        min-height: 40vh;
      }
    </style>
  </body>
</html>
