---
// Tufte-style marginalia. Auto-numbered via a CSS counter scoped to the
// surrounding `.post` article.
//
// We do NOT wrap the body in a <details>/<summary> disclosure. The MDX
// author always writes the sidenote mid-paragraph (`text.<Sidenote>note</Sidenote>`),
// and browsers' HTML parser treats <details> as flow content: when encountered
// inside a <p>, the open <p> is closed automatically and <details> becomes a
// sibling of the paragraph. So the note would drop out of its sentence and
// render on its own line, regardless of CSS.
//
// Instead: a <button> toggle + a <span> body (both phrasing content, both
// legal children of <p>). The viewport-sync script in BaseLayout toggles the
// `is-open` class so the body is always visible on wide and collapsible by
// click on narrow.
---

<span class="sidenote"
  ><button
    type="button"
    class="sidenote__ref"
    aria-label="Sidenote"
    aria-expanded="false"><sup></sup></button
  ><span class="sidenote__body" role="note"><sup></sup> <slot /></span></span
>

<style is:global>
  .sidenote {
    counter-increment: sidenote;
    position: relative;
  }

  .sidenote__ref {
    appearance: none;
    margin: 0;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--color-accent);
    font: inherit;
    cursor: pointer;
    display: inline;
  }

  .sidenote__ref sup {
    font-feature-settings: "sups";
    font-size: 0.75em;
  }

  .sidenote__ref sup::before {
    content: counter(sidenote);
  }

  .sidenote__body {
    display: block;
    margin: 0.75rem 0;
    padding: 0.5rem 0 0.5rem 1rem;
    border-left: 2px solid var(--color-rule);
    background: color-mix(in oklab, var(--color-surface) 70%, transparent);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--color-fg-muted);
  }

  .sidenote__body sup {
    color: var(--color-accent);
    margin-right: 0.3em;
    font-style: normal;
    font-feature-settings: "sups";
  }

  .sidenote__body sup::before {
    content: counter(sidenote);
  }

  /* Narrow: body hidden by default, shown when sidenote is .is-open. */
  @media (max-width: 61.99rem) {
    .sidenote__body {
      display: none;
    }
    .sidenote.is-open .sidenote__body {
      display: block;
    }
  }

  /* Wide: body floats into the right gutter, anchored to the line where the
     superscript sits. The body column is 32rem; the float is 18rem with a
     negative right-margin that pulls it past the column edge. The ref button
     becomes inert since the body is already visible. */
  @media (min-width: 62rem) {
    .post__body .sidenote__body {
      float: right;
      clear: right;
      width: 18rem;
      margin: 0 -21rem 0.5rem 0;
      padding: 0 0 0 1rem;
      border-left: 1px solid var(--color-rule);
      background: transparent;
      font-size: 0.9rem;
    }

    .post__body .sidenote__ref {
      pointer-events: none;
    }
  }
</style>
