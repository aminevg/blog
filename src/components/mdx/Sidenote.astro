---
// Uses <button> + <span> (both phrasing content) because <details> would be
// closed out of any enclosing <p> by the HTML parser and drop out of its
// sentence. On narrow viewports the script below toggles `is-open` on the
// root to reveal the body; on wide viewports the body floats into the gutter.
---

<span data-sidenote-root class="group relative [counter-increment:sidenote]"
  ><button
    type="button"
    aria-label="Sidenote"
    aria-expanded="false"
    class="text-oxblood desktop:pointer-events-none focus-ring inline cursor-pointer appearance-none border-0 bg-transparent p-0 font-[inherit]"
    ><sup
      class="[font-feature-settings:'sups'] text-xs before:content-[counter(sidenote)]"
    ></sup></button
  ><span
    role="note"
    class="border-rule text-ink-muted max-desktop:group-[.is-open]:block desktop:float-right desktop:clear-right desktop:m-0 desktop:mb-2 desktop:-mr-84 desktop:block desktop:w-72 desktop:border-l desktop:border-rule desktop:bg-transparent desktop:p-0 desktop:pl-4 desktop:text-[0.9rem] my-3 hidden border-l-2 bg-[color-mix(in_oklab,var(--color-surface)_70%,transparent)] py-2 pl-4 font-serif text-[0.95rem] leading-[1.5] italic"
    ><sup
      class="text-oxblood mr-1 [font-feature-settings:'sups'] not-italic before:content-[counter(sidenote)]"
    ></sup>
    <slot /></span
  ></span
>

<script>
  const mql = window.matchMedia("(min-width: 62rem)");

  document.querySelectorAll("[data-sidenote-root]").forEach((root) => {
    const btn = root.querySelector("button");
    if (!btn) return;

    const sync = () => {
      const visible = mql.matches || root.classList.contains("is-open");
      btn.setAttribute("aria-expanded", String(visible));
    };

    btn.addEventListener("click", () => {
      root.classList.toggle("is-open");
      sync();
    });

    mql.addEventListener("change", sync);
    sync();
  });
</script>
