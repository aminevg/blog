---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

export interface Props {
  src: ImageMetadata | string;
  alt: string;
  caption?: string;
  number?: number;
  widths?: number[];
  sizes?: string;
}

const { src, alt, caption, number, widths, sizes } = Astro.props;
const isMetadata = typeof src !== "string";
---

<figure class="figure">
  {
    isMetadata ? (
      <Image
        src={src}
        alt={alt}
        widths={widths ?? [400, 800, 1200]}
        sizes={sizes ?? "(min-width: 48rem) 32rem, 100vw"}
        loading="lazy"
        decoding="async"
      />
    ) : (
      <img src={src} alt={alt} loading="lazy" decoding="async" />
    )
  }
  {
    caption && (
      <figcaption>
        {number !== undefined && (
          <span class="figure__number">Figure {number}.</span>
        )}{" "}
        <em>{caption}</em>
      </figcaption>
    )
  }
</figure>

<style>
  .figure {
    margin: 2rem 0;
  }

  .figure :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  .figure figcaption {
    margin-top: 0.625rem;
    font-family: var(--font-serif);
    font-size: 0.95rem;
    color: var(--color-fg-muted);
    line-height: 1.5;
  }

  .figure__number {
    font-style: normal;
    font-variant: small-caps;
    letter-spacing: 0.04em;
    color: var(--color-fg-subtle);
  }
</style>
