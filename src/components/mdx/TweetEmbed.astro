---
export interface Props {
  // Full tweet URL, e.g. https://twitter.com/user/status/12345
  url: string;
  // Optional caption line shown below the link.
  caption?: string;
}

const { url, caption } = Astro.props;
---
{/* Lightweight non-JS embed — link out rather than injecting the Twitter SDK. */}
<figure class="tweet">
  <a href={url} target="_blank" rel="noopener noreferrer" class="tweet__link">
    {url}
  </a>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .tweet {
    margin: 2rem 0;
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-surface);
    font-family: var(--font-sans);
    font-size: 0.9rem;
  }
  .tweet__link {
    color: var(--color-accent);
    word-break: break-all;
  }
  .tweet figcaption {
    margin-top: 0.5rem;
    color: var(--color-fg-muted);
    font-size: 0.8125rem;
  }
</style>
