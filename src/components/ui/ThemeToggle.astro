---
import type { Locale } from "~/config/site";
import { t } from "~/i18n/ui";

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);
---

<button
  type="button"
  class="theme-toggle"
  aria-label={strings.theme.toggleLabel}
  data-theme-toggle
>
  <span class="theme-toggle__icon theme-toggle__icon--light" aria-hidden="true">
    <svg
      viewBox="0 0 24 24"
      width="18"
      height="18"
      fill="none"
      stroke="currentColor"
      stroke-width="1.75"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="12" cy="12" r="4"></circle>
      <path
        d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
      ></path>
    </svg>
  </span>
  <span class="theme-toggle__icon theme-toggle__icon--dark" aria-hidden="true">
    <svg
      viewBox="0 0 24 24"
      width="18"
      height="18"
      fill="none"
      stroke="currentColor"
      stroke-width="1.75"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
    </svg>
  </span>
  <span
    class="theme-toggle__icon theme-toggle__icon--system"
    aria-hidden="true"
  >
    <svg
      viewBox="0 0 24 24"
      width="18"
      height="18"
      fill="none"
      stroke="currentColor"
      stroke-width="1.75"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <rect x="3" y="4" width="18" height="12" rx="2"></rect>
      <path d="M8 20h8M12 16v4"></path>
    </svg>
  </span>
</button>

<script>
  const STORAGE_KEY = "theme";

  type ThemeState = "light" | "dark" | "system";

  function readState(): ThemeState {
    const stored = localStorage.getItem(STORAGE_KEY);
    return stored === "light" || stored === "dark" ? stored : "system";
  }

  function resolveEffective(state: ThemeState): "light" | "dark" {
    if (state === "light" || state === "dark") return state;
    return window.matchMedia("(prefers-color-scheme: dark)").matches
      ? "dark"
      : "light";
  }

  function applyState(state: ThemeState) {
    const effective = resolveEffective(state);
    document.documentElement.dataset.theme = effective;
    for (const button of document.querySelectorAll<HTMLElement>(
      "[data-theme-toggle]",
    )) {
      button.dataset.state = state;
    }
  }

  function cycle(state: ThemeState): ThemeState {
    if (state === "light") return "dark";
    if (state === "dark") return "system";
    return "light";
  }

  function persist(state: ThemeState) {
    if (state === "system") {
      localStorage.removeItem(STORAGE_KEY);
    } else {
      localStorage.setItem(STORAGE_KEY, state);
    }
  }

  function init() {
    applyState(readState());

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      const button = target.closest<HTMLElement>("[data-theme-toggle]");
      if (!button) return;
      const next = cycle(readState());
      persist(next);
      applyState(next);
    });

    window
      .matchMedia("(prefers-color-scheme: dark)")
      .addEventListener("change", () => {
        if (readState() === "system") applyState("system");
      });
  }

  init();
  document.addEventListener("astro:after-swap", init);
</script>

<style>
  .theme-toggle {
    --size: 2.25rem;
    display: inline-grid;
    place-items: center;
    width: var(--size);
    height: var(--size);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-surface-raised);
    color: var(--color-fg-muted);
    cursor: pointer;
    transition:
      color 120ms ease,
      border-color 120ms ease,
      background 120ms ease;
    position: relative;
  }

  .theme-toggle:hover {
    color: var(--color-fg);
    border-color: var(--color-border-strong);
  }

  .theme-toggle__icon {
    position: absolute;
    display: grid;
    place-items: center;
    opacity: 0;
    transform: scale(0.8);
    transition:
      opacity 120ms ease,
      transform 120ms ease;
  }

  /* States: visible icon per state. */
  [data-state="light"] .theme-toggle__icon--light,
  [data-state="dark"] .theme-toggle__icon--dark,
  [data-state="system"] .theme-toggle__icon--system {
    opacity: 1;
    transform: scale(1);
  }
</style>
