---
import { Image } from "astro:assets";
import type { TalkEntry } from "~/lib/content";
import type { Locale } from "~/config/site";
import { talkSlug } from "~/lib/content";
import { talkUrl } from "~/lib/paths";
import FormattedDate from "~/components/ui/FormattedDate.astro";

export interface Props {
  entry: TalkEntry;
  locale: Locale;
}

const { entry, locale } = Astro.props;
const slug = talkSlug(entry);
const href = talkUrl(locale, slug);
const { title, event, eventDate, venue, thumbnail } = entry.data;
const transitionName = `thumb-talk-${slug}`;
---
<article class="talk-card">
  <a href={href} class="talk-card__link">
    {thumbnail && (
      <div class="talk-card__media" style={`view-transition-name: ${transitionName}`}>
        <Image
          src={thumbnail}
          alt=""
          widths={[320, 640, 960]}
          sizes="(min-width: 48rem) 280px, 100vw"
          loading="lazy"
          decoding="async"
        />
      </div>
    )}
    <div class="talk-card__body">
      <h3 class="talk-card__title">{title}</h3>
      <p class="talk-card__meta">
        <span class="talk-card__event">{event}</span>
        {venue && <span class="talk-card__venue"> · {venue}</span>}
        <span class="talk-card__sep"> · </span>
        <FormattedDate date={eventDate} locale={locale} />
      </p>
    </div>
  </a>
</article>

<style>
  .talk-card {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .talk-card:last-child {
    border-bottom: none;
  }

  .talk-card__link {
    display: grid;
    grid-template-columns: 7.5rem 1fr;
    gap: 1.25rem;
    align-items: start;
    text-decoration: none;
    color: inherit;
  }

  .talk-card__media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 0.25rem;
    border: 1px solid var(--color-border);
  }

  .talk-card__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .talk-card__title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.3;
    margin: 0 0 0.375rem;
    color: var(--color-fg);
    transition: color 120ms ease;
  }

  .talk-card__link:hover .talk-card__title {
    color: var(--color-accent-strong);
  }

  .talk-card__meta {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-fg-muted);
    margin: 0;
  }

  .talk-card__event {
    font-weight: 500;
    color: var(--color-fg);
  }

  @media (max-width: 40rem) {
    .talk-card__link {
      grid-template-columns: 5.5rem 1fr;
      gap: 1rem;
    }
  }
</style>
