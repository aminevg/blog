---
import { Image } from "astro:assets";
import type { PostEntry } from "~/lib/content";
import type { Locale } from "~/config/site";
import { postSlug } from "~/lib/content";
import { postUrl } from "~/lib/paths";
import FormattedDate from "~/components/ui/FormattedDate.astro";

export interface Props {
  entry: PostEntry;
  locale: Locale;
}

const { entry, locale } = Astro.props;
const slug = postSlug(entry);
const href = postUrl(locale, slug);
const { title, description, pubDate, heroImage } = entry.data;
const transitionName = `thumb-post-${slug}`;
---
<article class="post-card">
  <a href={href} class="post-card__link">
    {heroImage && (
      <div class="post-card__media" style={`view-transition-name: ${transitionName}`}>
        <Image
          src={heroImage}
          alt=""
          widths={[320, 640]}
          sizes="(min-width: 48rem) 180px, 40vw"
          loading="lazy"
          decoding="async"
        />
      </div>
    )}
    <div class="post-card__body">
      <h3 class="post-card__title">{title}</h3>
      <p class="post-card__description">{description}</p>
      <p class="post-card__meta">
        <FormattedDate date={pubDate} locale={locale} />
      </p>
    </div>
  </a>
</article>

<style>
  .post-card {
    border-bottom: 1px solid var(--color-border);
    padding: 1.5rem 0;
  }

  .post-card:first-child {
    padding-top: 0;
  }

  .post-card:last-child {
    border-bottom: none;
  }

  .post-card__link {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1.5rem;
    align-items: start;
    text-decoration: none;
    color: inherit;
  }

  .post-card__media {
    order: 2;
    flex-shrink: 0;
    width: 6.5rem;
    height: 4.5rem;
    overflow: hidden;
    border-radius: 0.25rem;
    border: 1px solid var(--color-border);
  }

  .post-card__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .post-card__body {
    order: 1;
    min-width: 0;
  }

  .post-card__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.15rem, 2vw, 1.4rem);
    letter-spacing: -0.01em;
    line-height: 1.25;
    margin: 0 0 0.375rem;
    color: var(--color-fg);
    transition: color 120ms ease;
  }

  .post-card__link:hover .post-card__title {
    color: var(--color-accent-strong);
  }

  .post-card__description {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-fg-muted);
    margin: 0 0 0.5rem;
    max-width: 52ch;
  }

  .post-card__meta {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-fg-subtle);
    margin: 0;
  }
</style>
