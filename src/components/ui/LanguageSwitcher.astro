---
import type { Locale } from "~/config/site";
import { t, otherLocale } from "~/i18n/ui";

export interface Props {
  locale: Locale;
  // Path (within the site) to the equivalent page in the *other* locale.
  // Pass `null` when no translation exists.
  otherHref: string | null;
}

const { locale, otherHref } = Astro.props;
const target = otherLocale(locale);
const strings = t(locale);

const targetLabel = target === "en" ? strings.languageSwitcher.toEnglish : strings.languageSwitcher.toJapanese;
const missingLabel =
  target === "en"
    ? strings.languageSwitcher.onlyAvailableInJapanese
    : strings.languageSwitcher.onlyAvailableInEnglish;
---
{otherHref ? (
  <a
    href={otherHref}
    class="lang-switch"
    hreflang={target}
    lang={target}
    rel="alternate"
  >
    {targetLabel}
  </a>
) : (
  <span class="lang-switch lang-switch--disabled" aria-disabled="true">
    {missingLabel}
  </span>
)}

<style>
  .lang-switch {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    padding: 0.375rem 0.75rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: var(--color-surface-raised);
    color: var(--color-fg-muted);
    transition: color 120ms ease, border-color 120ms ease;
    display: inline-flex;
    align-items: center;
    height: 2.25rem;
  }

  .lang-switch:hover {
    color: var(--color-fg);
    border-color: var(--color-border-strong);
  }

  .lang-switch--disabled {
    color: var(--color-fg-subtle);
    cursor: not-allowed;
  }

  .lang-switch--disabled:hover {
    color: var(--color-fg-subtle);
    border-color: var(--color-border);
  }
</style>
