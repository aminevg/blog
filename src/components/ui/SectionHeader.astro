---
export interface Props {
  title: string;
  viewAllHref?: string;
  viewAllLabel?: string;
  description?: string;
  level?: 1 | 2;
}

const { title, viewAllHref, viewAllLabel, description, level = 2 } = Astro.props;
const Tag = `h${level}` as const;
---
<header class="section-header">
  <div class="section-header__row">
    <Tag class="section-header__title">{title}</Tag>
    {viewAllHref && viewAllLabel && (
      <a href={viewAllHref} class="section-header__link">
        {viewAllLabel} <span aria-hidden="true">→</span>
      </a>
    )}
  </div>
  {description && <p class="section-header__description">{description}</p>}
</header>

<style>
  .section-header {
    margin: 0 0 1.75rem;
  }

  .section-header__row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .section-header__title {
    font-family: var(--font-display);
    font-weight: 500;
    letter-spacing: -0.015em;
    font-size: clamp(1.375rem, 2.6vw, 1.75rem);
    line-height: 1.2;
    margin: 0;
    color: var(--color-fg);
  }

  .section-header__link {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    letter-spacing: 0.02em;
    text-decoration: none;
    color: var(--color-fg-muted);
    flex-shrink: 0;
  }

  .section-header__link:hover {
    color: var(--color-accent);
  }

  .section-header__description {
    font-family: var(--font-body);
    color: var(--color-fg-muted);
    font-size: 1rem;
    line-height: 1.5;
    max-width: 48ch;
    margin: 0.5rem 0 0;
  }
</style>
