---
import type { Locale } from "~/config/site";
import { SITE } from "~/config/site";

export interface Props {
  locale: Locale;
  title: string;
  description: string;
  canonical?: string | URL;
  ogImage?: string | URL;
  alternateUrl?: string | null;
  xDefaultUrl?: string;
  article?: {
    publishedTime?: Date;
    modifiedTime?: Date;
  };
}

const {
  locale,
  title,
  description,
  canonical,
  ogImage,
  alternateUrl = null,
  xDefaultUrl,
  article,
} = Astro.props;

const siteUrl = Astro.site ?? new URL("http://localhost");
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, siteUrl);
const resolvedOgImage = ogImage
  ? new URL(ogImage.toString(), siteUrl)
  : new URL("/og-default.png", siteUrl);

const fullTitle = title === SITE.title ? title : `${title} — ${SITE.title}`;

const otherLocaleCode: Locale = locale === "en" ? "ja" : "en";
---

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />

  <link rel="canonical" href={canonicalUrl} />

  {
    alternateUrl && (
      <>
        <link rel="alternate" hreflang={locale} href={canonicalUrl} />
        <link
          rel="alternate"
          hreflang={otherLocaleCode}
          href={new URL(alternateUrl, siteUrl)}
        />
      </>
    )
  }
  {
    xDefaultUrl && (
      <link
        rel="alternate"
        hreflang="x-default"
        href={new URL(xDefaultUrl, siteUrl)}
      />
    )
  }

  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content={article ? "article" : "website"} />
  <meta property="og:image" content={resolvedOgImage} />
  <meta property="og:site_name" content={SITE.title} />
  <meta property="og:locale" content={locale === "en" ? "en_US" : "ja_JP"} />
  {
    alternateUrl && (
      <meta
        property="og:locale:alternate"
        content={otherLocaleCode === "en" ? "en_US" : "ja_JP"}
      />
    )
  }
  {
    article?.publishedTime && (
      <meta
        property="article:published_time"
        content={article.publishedTime.toISOString()}
      />
    )
  }
  {
    article?.modifiedTime && (
      <meta
        property="article:modified_time"
        content={article.modifiedTime.toISOString()}
      />
    )
  }

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={resolvedOgImage} />

  <meta
    name="theme-color"
    media="(prefers-color-scheme: light)"
    content="#fdf9f0"
  />
  <meta
    name="theme-color"
    media="(prefers-color-scheme: dark)"
    content="#1a1614"
  />

  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

  <link
    rel="alternate"
    type="application/rss+xml"
    title={`${SITE.title} — EN`}
    href="/en/rss.xml"
  />
  <link
    rel="alternate"
    type="application/rss+xml"
    title={`${SITE.title} — JA`}
    href="/ja/rss.xml"
  />

  <link rel="alternate" type="text/markdown" href={`/${locale}/llms.txt`} />

  <slot />
</head>
