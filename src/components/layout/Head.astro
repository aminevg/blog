---
import type { Locale } from "~/config/site";
import { SITE } from "~/config/site";
import ThemeScript from "~/components/layout/ThemeScript.astro";

export interface Props {
  locale: Locale;
  title: string;
  description: string;
  // Canonical URL for this page. If omitted, Astro.url is used.
  canonical?: string | URL;
  // OG image URL (absolute or relative to site).
  ogImage?: string | URL;
  // When both translations exist, pass the URL of the sibling.
  alternateUrl?: string | null;
  // Always emit `x-default` → this URL (English version).
  xDefaultUrl?: string;
  // Article-specific metadata.
  article?: {
    publishedTime?: Date;
    modifiedTime?: Date;
  };
}

const {
  locale,
  title,
  description,
  canonical,
  ogImage,
  alternateUrl = null,
  xDefaultUrl,
  article,
} = Astro.props;

const siteUrl = Astro.site ?? new URL("http://localhost");
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, siteUrl);
const resolvedOgImage = ogImage
  ? new URL(ogImage.toString(), siteUrl)
  : new URL("/og-default.png", siteUrl);

const fullTitle = title === SITE.title ? title : `${title} — ${SITE.title}`;

const otherLocaleCode: Locale = locale === "en" ? "ja" : "en";
---

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />

  <ThemeScript />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />

  <link rel="canonical" href={canonicalUrl} />

  {
    alternateUrl && (
      <>
        <link rel="alternate" hreflang={locale} href={canonicalUrl} />
        <link
          rel="alternate"
          hreflang={otherLocaleCode}
          href={new URL(alternateUrl, siteUrl)}
        />
      </>
    )
  }
  {
    xDefaultUrl && (
      <link
        rel="alternate"
        hreflang="x-default"
        href={new URL(xDefaultUrl, siteUrl)}
      />
    )
  }

  {/* Open Graph */}
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content={article ? "article" : "website"} />
  <meta property="og:image" content={resolvedOgImage} />
  <meta property="og:site_name" content={SITE.title} />
  <meta property="og:locale" content={locale === "en" ? "en_US" : "ja_JP"} />
  {
    alternateUrl && (
      <meta
        property="og:locale:alternate"
        content={otherLocaleCode === "en" ? "en_US" : "ja_JP"}
      />
    )
  }
  {
    article?.publishedTime && (
      <meta
        property="article:published_time"
        content={article.publishedTime.toISOString()}
      />
    )
  }
  {
    article?.modifiedTime && (
      <meta
        property="article:modified_time"
        content={article.modifiedTime.toISOString()}
      />
    )
  }

  {/* Twitter / X */}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={resolvedOgImage} />

  {/* Theme color per light/dark */}
  <meta
    name="theme-color"
    media="(prefers-color-scheme: light)"
    content="#f7f4ee"
  />
  <meta
    name="theme-color"
    media="(prefers-color-scheme: dark)"
    content="#1a1815"
  />

  {/* Icons / manifest */}
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="icon" href="/favicon.ico" sizes="32x32" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  {/* RSS */}
  <link
    rel="alternate"
    type="application/rss+xml"
    title={`${SITE.title} — EN`}
    href="/en/rss.xml"
  />
  <link
    rel="alternate"
    type="application/rss+xml"
    title={`${SITE.title} — JA`}
    href="/ja/rss.xml"
  />

  {/* llms.txt */}
  <link rel="alternate" type="text/markdown" href={`/${locale}/llms.txt`} />

  {/* Preload Latin variable font for EN pages only — avoids CJK page waste. */}
  {
    locale === "en" && (
      <link
        rel="preload"
        href="/fonts/source-serif-4.woff2"
        as="font"
        type="font/woff2"
        crossorigin
      />
    )
  }
</head>
