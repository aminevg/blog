---
import type { Locale } from "~/config/site";
import { SITE } from "~/config/site";
import { t } from "~/i18n/ui";
import { rssUrl } from "~/lib/paths";
import NavLink from "~/components/ui/NavLink.astro";

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);
const xHref = `https://x.com/${SITE.social.x}`;
const githubHref = `https://github.com/${SITE.social.github}`;
---

<footer class="border-rule text-ink-muted kicker mt-16 border-t pt-6">
  <nav
    class="flex flex-wrap items-baseline gap-[0.65rem]"
    aria-label="Social and syndication"
  >
    <NavLink href={xHref} target="_blank" rel="me noopener">X</NavLink>
    <span class="text-ink-subtle" aria-hidden="true">·</span>
    <NavLink href={githubHref} target="_blank" rel="me noopener">GitHub</NavLink
    >
    <span class="text-ink-subtle" aria-hidden="true">·</span>
    <NavLink href={rssUrl(locale)}>{strings.feed.rss}</NavLink>
  </nav>
</footer>
