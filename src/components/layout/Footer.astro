---
import type { Locale } from "~/config/site";
import { SITE } from "~/config/site";
import { t } from "~/i18n/ui";
import { rssUrl, localeHome } from "~/lib/paths";

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="site-footer__inner">
    <p class="site-footer__copy">
      <a href={localeHome(locale)}>{SITE.author.name}</a>
      <span class="site-footer__sep">·</span>
      <span>© {year}</span>
    </p>
    <nav class="site-footer__nav" aria-label="Footer">
      <a href={rssUrl("en")}>{strings.feed.rss} (EN)</a>
      <a href={rssUrl("ja")}>{strings.feed.rss} (JA)</a>
      <a href={SITE.author.url} rel="me">aminevg.dev</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 6rem;
    border-top: 1px solid var(--color-border);
    padding: 2rem 0 3rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-fg-muted);
  }

  .site-footer__inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 clamp(1rem, 4vw, 2rem);
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .site-footer__copy a {
    font-weight: 500;
    color: var(--color-fg);
    text-decoration: none;
  }

  .site-footer__sep {
    margin: 0 0.4rem;
    color: var(--color-fg-subtle);
  }

  .site-footer__nav {
    display: flex;
    gap: 1.25rem;
  }

  .site-footer__nav a {
    color: var(--color-fg-muted);
    text-decoration: none;
  }

  .site-footer__nav a:hover {
    color: var(--color-fg);
  }
</style>
