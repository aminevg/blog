---
import type { Locale } from "~/config/site";
import { SITE } from "~/config/site";
import { t, otherLocale } from "~/i18n/ui";
import { localeHome, localeBlog, localeTalks, localeAbout } from "~/lib/paths";
import Link from "~/components/ui/Link.astro";

export interface Props {
  locale: Locale;
  // URL of the equivalent page in the other locale, or null if no direct
  // translation exists — in which case the switcher falls back to the other
  // locale's home so the link is always clickable.
  otherLocaleHref: string | null;
}

const { locale, otherLocaleHref } = Astro.props;
const strings = t(locale);
const subtitle = SITE.subtitle[locale];

const navItems = [
  { href: localeBlog(locale), label: strings.nav.blog },
  { href: localeTalks(locale), label: strings.nav.talks },
  { href: localeAbout(locale), label: strings.nav.about },
];

const currentPath = Astro.url.pathname;
const target = otherLocale(locale);
const langLabel =
  target === "en"
    ? strings.languageSwitcher.toEnglish
    : strings.languageSwitcher.toJapanese;
const switcherHref = otherLocaleHref ?? localeHome(target);

const navAnchor =
  "hover:border-ink aria-[current=page]:text-ink aria-[current=page]:border-oxblood border-b border-transparent pb-[0.1rem] no-underline transition-colors duration-150";
---

<header class="border-rule mb-8 border-b pb-8">
  {/* Not an <h1> — each page owns its own page-level heading. */}
  <p
    class="text-hero mb-3 font-serif leading-[0.95] font-medium tracking-[-0.01em] italic"
  >
    <Link href={localeHome(locale)} rel="home">{SITE.author.name}</Link>
  </p>
  <p class="text-ink-muted mb-6 max-w-[34ch] text-xl"><em>{subtitle}</em></p>
  <nav
    class="text-ink-muted flex flex-wrap items-baseline gap-[0.65rem] font-sans text-[0.72rem] font-medium tracking-[0.14em] uppercase"
    aria-label="Primary"
  >
    {
      navItems.map((item, index) => (
        <>
          {index > 0 && (
            <span class="text-ink-subtle" aria-hidden="true">
              ·
            </span>
          )}
          <Link
            href={item.href}
            class={navAnchor}
            aria-current={
              currentPath.startsWith(item.href) ? "page" : undefined
            }
          >
            {item.label}
          </Link>
        </>
      ))
    }
    <span class="text-ink-subtle" aria-hidden="true">·</span>
    <Link
      href={switcherHref}
      class={`${navAnchor} font-serif text-[0.95rem] font-normal tracking-normal normal-case italic`}
      hreflang={target}
      lang={target}
      rel="alternate"
    >
      {langLabel}
    </Link>
  </nav>
</header>
