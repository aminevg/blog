---
import type { Locale } from "~/config/site";
import { SITE } from "~/config/site";
import { t } from "~/i18n/ui";
import ThemeToggle from "~/components/ui/ThemeToggle.astro";
import LanguageSwitcher from "~/components/ui/LanguageSwitcher.astro";
import {
  localeHome,
  localeBlog,
  localeTalks,
  localeAbout,
} from "~/lib/paths";

export interface Props {
  locale: Locale;
  // URL of the equivalent page in the other locale, or null if absent.
  otherLocaleHref: string | null;
}

const { locale, otherLocaleHref } = Astro.props;
const strings = t(locale);

const navItems = [
  { href: localeBlog(locale), label: strings.nav.blog },
  { href: localeTalks(locale), label: strings.nav.talks },
  { href: localeAbout(locale), label: strings.nav.about },
];

const currentPath = Astro.url.pathname;
---
<header class="site-header" aria-label="Site header">
  <div class="site-header__inner">
    <a href={localeHome(locale)} class="site-header__brand" rel="home">
      <span class="site-header__brand-name">{SITE.author.name}</span>
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      <ul>
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={currentPath.startsWith(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="site-header__controls">
      <LanguageSwitcher locale={locale} otherHref={otherLocaleHref} />
      <ThemeToggle locale={locale} />
    </div>
  </div>
</header>

<style>
  .site-header {
    view-transition-name: site-header;
    position: sticky;
    top: 0;
    z-index: 20;
    background: color-mix(in oklab, var(--color-bg) 90%, transparent);
    backdrop-filter: saturate(1.2) blur(10px);
    border-bottom: 1px solid var(--color-border);
  }

  .site-header__inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0.9rem clamp(1rem, 4vw, 2rem);
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: clamp(1rem, 4vw, 2rem);
    align-items: center;
  }

  .site-header__brand {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.0625rem;
    letter-spacing: -0.01em;
    text-decoration: none;
    color: var(--color-fg);
  }

  .site-header__nav ul {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    letter-spacing: 0.01em;
  }

  .site-header__nav a {
    color: var(--color-fg-muted);
    text-decoration: none;
    transition: color 120ms ease;
  }

  .site-header__nav a:hover,
  .site-header__nav a[aria-current="page"] {
    color: var(--color-fg);
  }

  .site-header__controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  @media (max-width: 42rem) {
    .site-header__inner {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
      gap: 0.5rem 1rem;
    }
    .site-header__brand {
      grid-column: 1;
      grid-row: 1;
    }
    .site-header__controls {
      grid-column: 2;
      grid-row: 1;
    }
    .site-header__nav {
      grid-column: 1 / -1;
      grid-row: 2;
    }
    .site-header__nav ul {
      gap: 1rem;
    }
  }
</style>
