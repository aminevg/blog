---
import type { Locale } from "~/config/site";
import { SITE } from "~/config/site";

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const description = SITE.description[locale];
const title =
  locale === "en"
    ? "Notes on software, SRE, and life between Paris and Tokyo."
    : "ソフトウェア・SRE、そしてパリと東京のあいだで書くノート。";
const subtitle =
  locale === "en"
    ? "Writing by Amine Ilidrissi — occasional, long-form, unrushed."
    : "Amine Ilidrissi のブログ。ゆっくり、長めに、気が向いたときに。";
---
<section class="hero">
  <p class="hero__eyebrow">{description}</p>
  <h1 class="hero__title">{title}</h1>
  <p class="hero__subtitle">{subtitle}</p>
</section>

<style>
  .hero {
    padding: clamp(3rem, 8vw, 5rem) 0 clamp(2.5rem, 6vw, 4rem);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 3rem;
  }

  .hero__eyebrow {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-fg-muted);
    margin: 0 0 1rem;
  }

  .hero__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.875rem, 4.5vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--color-fg);
    margin: 0 0 1rem;
    max-width: 20ch;
  }

  .hero__subtitle {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--color-fg-muted);
    margin: 0;
    max-width: 42ch;
  }
</style>
