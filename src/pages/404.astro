---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Link from "~/components/ui/Link.astro";
import { t } from "~/i18n/ui";
import { localeHome } from "~/lib/paths";

const en = t("en").notFound;
const ja = t("ja").notFound;

const kicker =
  "text-ink-subtle mb-3 font-sans text-[0.72rem] font-medium tracking-[0.14em] uppercase";
const title =
  "text-page-title text-ink mb-3 font-serif leading-[1.05] font-medium tracking-[-0.01em] italic";
const body = "text-ink-muted m-0 mb-4 max-w-[32rem] text-lg";
const ctaLink =
  "decoration-rule hover:decoration-oxblood hover:text-oxblood underline";
---

<BaseLayout
  locale="en"
  title={en.title}
  description={en.body}
  alternateUrl={null}
>
  <section class="my-8" lang="en" aria-labelledby="not-found-title-en">
    <p class={kicker}>{en.kicker}</p>
    <h1 id="not-found-title-en" class={title}>{en.title}</h1>
    <p class={body}>
      <em>{en.body}</em>
    </p>
    <p class="m-0 text-lg">
      <Link href={localeHome("en")} class={ctaLink}>{en.home}</Link>.
    </p>
  </section>

  <hr class="border-rule my-10 border-0 border-t" />

  <section class="my-8" lang="ja" aria-labelledby="not-found-title-ja">
    <p class={kicker}>{ja.kicker}</p>
    <h2 id="not-found-title-ja" class={title}>{ja.title}</h2>
    <p class={body}>
      <em>{ja.body}</em>
    </p>
    <p class="m-0 text-lg">
      <Link href={localeHome("ja")} class={ctaLink}>{ja.home}</Link>
    </p>
  </section>
</BaseLayout>
