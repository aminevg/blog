---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { t } from "~/i18n/ui";

const en = t("en").notFound;
const ja = t("ja").notFound;
---

<BaseLayout
  locale="en"
  title={en.title}
  description={en.body}
  alternateUrl={null}
>
  <section class="not-found" lang="en" aria-labelledby="not-found-title-en">
    <p class="not-found__kicker">{en.kicker}</p>
    <h1 id="not-found-title-en" class="not-found__title">{en.title}</h1>
    <p class="not-found__body">
      <em>{en.body}</em>
    </p>
    <p class="not-found__cta">
      <a href="/en/">{en.home}</a>.
    </p>
  </section>

  <hr class="not-found__rule" />

  <section class="not-found" lang="ja" aria-labelledby="not-found-title-ja">
    <p class="not-found__kicker">{ja.kicker}</p>
    <h2 id="not-found-title-ja" class="not-found__title">{ja.title}</h2>
    <p class="not-found__body">
      <em>{ja.body}</em>
    </p>
    <p class="not-found__cta">
      <a href="/ja/">{ja.home}</a>
    </p>
  </section>
</BaseLayout>

<style>
  .not-found {
    margin: 2rem 0;
  }

  .not-found__kicker {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-fg-subtle);
    margin: 0 0 0.75rem;
  }

  .not-found__title {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(2rem, 5vw, 3rem);
    letter-spacing: -0.01em;
    line-height: 1.05;
    color: var(--color-fg);
    margin: 0 0 0.75rem;
  }

  .not-found__body {
    color: var(--color-fg-muted);
    margin: 0 0 1rem;
    max-width: 32rem;
  }

  .not-found__cta {
    margin: 0;
  }

  .not-found__cta a {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: var(--color-rule);
    text-underline-offset: 0.2em;
  }

  .not-found__cta a:hover {
    color: var(--color-accent);
    text-decoration-color: var(--color-accent);
  }

  .not-found__rule {
    border: none;
    border-top: 1px solid var(--color-rule);
    margin: 2.5rem 0;
  }
</style>
