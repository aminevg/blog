---
import { sample } from "./_sample-data";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Editorial — design exploration</title>
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;0,8..60,600;1,8..60,400&display=swap"
    />
  </head>
  <body>
    <a href="/design-explorations/" class="back">← All variants</a>

    <header class="chrome">
      <a href="#" class="chrome__brand">{sample.author}</a>
      <nav class="chrome__nav">
        <a href="#" aria-current="page">Blog</a>
        <a href="#">Talks</a>
        <a href="#">About</a>
      </nav>
      <div class="chrome__controls">
        <a href="#" class="chrome__lang">日本語</a>
        <button class="chrome__theme" aria-label="Theme">
          <svg
            viewBox="0 0 20 20"
            width="16"
            height="16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <circle cx="10" cy="10" r="3.5"></circle>
            <path
              d="M10 2v1.6M10 16.4V18M2 10h1.6M16.4 10H18M4.22 4.22l1.13 1.13M14.65 14.65l1.13 1.13M4.22 15.78l1.13-1.13M14.65 5.35l1.13-1.13"
              stroke-linecap="round"></path>
          </svg>
        </button>
      </div>
    </header>

    <main class="page">
      <section class="hero">
        <p class="hero__eyebrow">{sample.tagline.eyebrow}</p>
        <h1 class="hero__title">{sample.tagline.title}</h1>
        <p class="hero__subtitle">{sample.tagline.subtitle}</p>
      </section>

      <section class="section">
        <header class="section__head">
          <h2>Latest posts</h2>
          <a href="#">View all posts <span aria-hidden="true">→</span></a>
        </header>
        <ul class="posts">
          {
            sample.posts.map((p) => (
              <li class="post">
                <a href="#" class="post__link">
                  <div>
                    <h3 class="post__title">{p.title}</h3>
                    <p class="post__description">{p.description}</p>
                    <p class="post__meta">
                      <time>{p.date}</time> · {p.read}
                    </p>
                  </div>
                  <span class="post__chevron" aria-hidden="true">
                    ↗
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="section">
        <header class="section__head">
          <h2>Recent talks</h2>
          <a href="#">View all talks <span aria-hidden="true">→</span></a>
        </header>
        <ul class="talks">
          {
            sample.talks.map((t) => (
              <li class="talk">
                <a href="#" class="talk__link">
                  <span class="talk__badge">Talk</span>
                  <span class="talk__body">
                    <span class="talk__title">{t.title}</span>
                    <span class="talk__meta">
                      {t.event} · {t.venue} · {t.date}
                    </span>
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </main>

    <footer class="footer">
      <span>© 2026 {sample.author}</span>
      <span>Editorial variant · <a href="/design-explorations/">switch</a></span
      >
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f7f4ee;
    --surface: #efe8da;
    --fg: #1a1512;
    --fg-muted: #6b635a;
    --fg-subtle: #958c7f;
    --border: #e0d5bf;
    --accent: #7b2d26;
    --accent-soft: rgba(123, 45, 38, 0.08);
  }
  * {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--fg);
    font-family: "Source Serif 4", ui-serif, Georgia, serif;
    line-height: 1.6;
    font-feature-settings: "kern", "liga", "onum";
  }
  a {
    color: inherit;
  }
  .back {
    position: fixed;
    top: 1rem;
    left: 1rem;
    font-family: ui-monospace, monospace;
    font-size: 0.75rem;
    color: var(--fg-muted);
    text-decoration: none;
    background: var(--bg);
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    z-index: 10;
  }
  .chrome {
    max-width: 72rem;
    margin: 0 auto;
    padding: 1.25rem clamp(1rem, 4vw, 2rem);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: clamp(1rem, 4vw, 2.5rem);
    border-bottom: 1px solid var(--border);
  }
  .chrome__brand {
    font-family: Fraunces, ui-serif, serif;
    font-size: 1.0625rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    text-decoration: none;
  }
  .chrome__nav {
    display: flex;
    gap: 1.75rem;
    font-family: "Source Serif 4", ui-serif, serif;
    font-size: 0.95rem;
  }
  .chrome__nav a {
    text-decoration: none;
    color: var(--fg-muted);
  }
  .chrome__nav a[aria-current="page"] {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 4px;
  }
  .chrome__controls {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  .chrome__lang,
  .chrome__theme {
    font-family: "Source Serif 4", serif;
    font-size: 0.85rem;
    padding: 0.4rem 0.75rem;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--fg-muted);
    text-decoration: none;
    cursor: pointer;
    display: inline-grid;
    place-items: center;
  }
  .chrome__theme {
    width: 2rem;
    height: 2rem;
    padding: 0;
  }

  .page {
    max-width: 42rem;
    margin: 0 auto;
    padding: clamp(2.5rem, 6vw, 4rem) clamp(1.25rem, 4vw, 2rem) 4rem;
  }
  .hero {
    padding: clamp(2.5rem, 6vw, 4rem) 0 clamp(2rem, 4vw, 3rem);
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }
  .hero__eyebrow {
    font-family: "Source Serif 4", serif;
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin: 0 0 1rem;
  }
  .hero__title {
    font-family: Fraunces, ui-serif, serif;
    font-weight: 400;
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-variation-settings:
      "SOFT" 50,
      "WONK" 0;
    letter-spacing: -0.025em;
    line-height: 1.08;
    margin: 0 0 1rem;
    max-width: 20ch;
  }
  .hero__subtitle {
    font-size: 1.0625rem;
    color: var(--fg-muted);
    max-width: 42ch;
    margin: 0;
  }
  .section {
    margin-bottom: 3.5rem;
  }
  .section__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }
  .section__head h2 {
    font-family: Fraunces, serif;
    font-weight: 500;
    font-size: 1.5rem;
    letter-spacing: -0.015em;
    margin: 0;
  }
  .section__head a {
    font-family: "Source Serif 4", serif;
    font-size: 0.85rem;
    color: var(--fg-muted);
    text-decoration: none;
  }
  .section__head a:hover {
    color: var(--accent);
  }

  .posts,
  .talks {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .post {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
  }
  .post:first-child {
    padding-top: 0;
  }
  .post:last-child {
    border-bottom: none;
  }
  .post__link {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    align-items: start;
    text-decoration: none;
    color: inherit;
  }
  .post__title {
    font-family: Fraunces, serif;
    font-weight: 500;
    font-size: 1.35rem;
    letter-spacing: -0.01em;
    line-height: 1.25;
    margin: 0 0 0.45rem;
    transition: color 160ms ease;
  }
  .post__link:hover .post__title {
    color: var(--accent);
  }
  .post__description {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--fg-muted);
    margin: 0 0 0.6rem;
    max-width: 56ch;
  }
  .post__meta {
    font-family: "Source Serif 4", serif;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    margin: 0;
  }
  .post__chevron {
    font-family: ui-serif, serif;
    color: var(--fg-subtle);
    font-size: 1.1rem;
    margin-top: 0.1rem;
    transition:
      transform 200ms ease,
      color 200ms ease;
  }
  .post__link:hover .post__chevron {
    transform: translate(3px, -3px);
    color: var(--accent);
  }

  .talk {
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
  }
  .talk:last-child {
    border-bottom: none;
  }
  .talk__link {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    align-items: baseline;
    text-decoration: none;
    color: inherit;
  }
  .talk__badge {
    font-family: "Source Serif 4", serif;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    padding: 0.1rem 0.5rem;
    border: 1px solid var(--accent);
    border-radius: 999px;
  }
  .talk__body {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .talk__title {
    font-family: Fraunces, serif;
    font-weight: 500;
    font-size: 1.05rem;
    letter-spacing: -0.005em;
  }
  .talk__meta {
    font-size: 0.85rem;
    color: var(--fg-muted);
  }

  .footer {
    max-width: 42rem;
    margin: 0 auto;
    padding: 2rem clamp(1.25rem, 4vw, 2rem) 4rem;
    font-family: "Source Serif 4", serif;
    font-size: 0.8125rem;
    color: var(--fg-subtle);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    border-top: 1px solid var(--border);
  }
  .footer a {
    color: var(--accent);
  }
</style>
