---
import { sample } from "./_sample-data";

const postCount = sample.posts.length.toString().padStart(2, "0");
const talkCount = sample.talks.length.toString().padStart(2, "0");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Brutalist dev — design exploration</title>
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400&family=Space+Grotesk:wght@400;500;600&display=swap"
    />
  </head>
  <body>
    <a href="/design-explorations/" class="back">◂ all variants</a>

    <div class="frame">
      <header class="chrome">
        <a href="#" class="chrome__brand">aminevg<span>.dev</span></a>
        <div class="chrome__ruler" aria-hidden="true">
          <span>—</span><span>—</span><span>—</span><span>—</span><span>—</span
          ><span>—</span><span>—</span><span>—</span><span>—</span><span>—</span
          ><span>—</span><span>—</span>
        </div>
        <nav class="chrome__nav">
          <a href="#" aria-current="page">blog<span>[{postCount}]</span></a>
          <a href="#">talks<span>[{talkCount}]</span></a>
          <a href="#">about</a>
          <a href="#" class="chrome__lang">JA</a>
        </nav>
      </header>

      <section class="stripe">
        <div>writer :: Amine Ilidrissi</div>
        <div>field :: SRE / Platforms</div>
        <div>base :: Paris + Tokyo</div>
        <div>rss :: <a href="#">/en/rss.xml</a></div>
      </section>

      <main>
        <section class="hero">
          <div class="hero__label">
            <span>/00</span>
            <span>intro</span>
          </div>
          <h1 class="hero__title">
            <span class="hero__title-line">Software.</span>
            <span class="hero__title-line">Operations.</span>
            <span class="hero__title-line hero__title-line--accent"
              >Long-form notes.</span
            >
          </h1>
          <p class="hero__subtitle">
            {sample.tagline.subtitle}
          </p>
        </section>

        <section class="block">
          <header class="block__head">
            <h2>
              <span class="block__number">/01</span>
              Posts — chronological
            </h2>
            <span class="block__counter">showing {postCount}</span>
          </header>
          <table class="posts">
            <thead>
              <tr>
                <th class="col-idx">idx</th>
                <th class="col-title">title</th>
                <th class="col-date">date</th>
                <th class="col-read">read</th>
              </tr>
            </thead>
            <tbody>
              {
                sample.posts.map((p, i) => (
                  <tr class="post-row">
                    <td class="col-idx">{String(i).padStart(2, "0")}</td>
                    <td class="col-title">
                      <a href="#" class="post-row__title">
                        {p.title}
                      </a>
                      <p class="post-row__description">{p.description}</p>
                    </td>
                    <td class="col-date">{p.date}</td>
                    <td class="col-read">{p.read}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </section>

        <section class="block">
          <header class="block__head">
            <h2>
              <span class="block__number">/02</span>
              Talks — outbound only
            </h2>
            <span class="block__counter">showing {talkCount}</span>
          </header>
          <ul class="talks">
            {
              sample.talks.map((t, i) => (
                <li class="talk">
                  <a href="#" class="talk__link">
                    <span class="talk__number">
                      /{String(i).padStart(2, "0")}
                    </span>
                    <span class="talk__title">{t.title}</span>
                    <span class="talk__meta">
                      <span>{t.event}</span>
                      <span>·</span>
                      <span>{t.venue}</span>
                      <span>·</span>
                      <span>{t.date}</span>
                    </span>
                    <span class="talk__cta">open slides ↗</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </section>
      </main>

      <footer class="footer">
        <span>© 2026 aminevg // static // built with astro 6</span>
        <span
          >brutalist variant · <a href="/design-explorations/">switch</a></span
        >
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f4f2ee;
    --paper: #ffffff;
    --fg: #0d0d0f;
    --fg-muted: #545457;
    --fg-subtle: #8a8a8c;
    --border: #0d0d0f;
    --accent: #e23b2d;
    --grid: rgba(13, 13, 15, 0.08);
  }
  * {
    box-sizing: border-box;
  }
  html,
  body {
    margin: 0;
  }
  body {
    background: var(--bg);
    color: var(--fg);
    font-family: "Space Grotesk", ui-sans-serif, system-ui, sans-serif;
    line-height: 1.55;
    font-size: 16px;
  }
  a {
    color: inherit;
  }
  .back {
    position: fixed;
    top: 0.75rem;
    left: 0.75rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    color: var(--fg-muted);
    text-decoration: none;
    background: var(--paper);
    padding: 0.25rem 0.6rem;
    border: 1px solid var(--border);
    z-index: 10;
  }
  .frame {
    max-width: 72rem;
    margin: 0 auto;
    background: var(--paper);
    border-left: 1px solid var(--border);
    border-right: 1px solid var(--border);
    min-height: 100vh;
  }
  .chrome {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.5rem;
    align-items: center;
    padding: 1rem clamp(1rem, 3vw, 2rem);
    border-bottom: 1px solid var(--border);
  }
  .chrome__brand {
    font-family: "JetBrains Mono", monospace;
    font-weight: 700;
    letter-spacing: -0.02em;
    font-size: 1rem;
    text-decoration: none;
  }
  .chrome__brand span {
    color: var(--accent);
  }
  .chrome__ruler {
    display: flex;
    gap: 0.25rem;
    overflow: hidden;
    font-family: "JetBrains Mono", monospace;
    color: var(--fg-subtle);
    font-size: 0.9rem;
    letter-spacing: 0;
    user-select: none;
  }
  .chrome__nav {
    display: flex;
    gap: 1.5rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.8125rem;
  }
  .chrome__nav a {
    text-decoration: none;
    color: var(--fg-muted);
    padding: 0.2rem 0;
  }
  .chrome__nav a span {
    color: var(--fg-subtle);
    margin-left: 0.15rem;
  }
  .chrome__nav a[aria-current="page"] {
    color: var(--accent);
    border-bottom: 2px solid var(--accent);
  }
  .chrome__lang {
    color: var(--fg) !important;
    font-weight: 700;
  }

  .stripe {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    border-bottom: 1px solid var(--border);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.75rem;
    color: var(--fg-muted);
  }
  .stripe > div {
    padding: 0.75rem 1rem;
    border-right: 1px solid var(--border);
  }
  .stripe > div:last-child {
    border-right: none;
  }
  .stripe a {
    color: var(--accent);
    text-decoration: none;
  }

  main {
    padding: 0 clamp(1rem, 3vw, 2rem);
  }

  .hero {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--border);
  }
  .hero__label {
    display: flex;
    gap: 1rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
    color: var(--fg-subtle);
    margin-bottom: 1.5rem;
  }
  .hero__title {
    font-family: "JetBrains Mono", monospace;
    font-weight: 700;
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin: 0 0 1.5rem;
  }
  .hero__title-line {
    display: block;
    font-feature-settings: "ss01";
  }
  .hero__title-line--accent {
    color: var(--accent);
    font-style: italic;
  }
  .hero__subtitle {
    max-width: 50ch;
    font-size: 1.125rem;
    color: var(--fg-muted);
    margin: 0;
  }

  .block {
    padding: 3rem 0;
    border-bottom: 1px solid var(--border);
  }
  .block:last-of-type {
    border-bottom: none;
  }
  .block__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.5rem;
  }
  .block__head h2 {
    font-family: "JetBrains Mono", monospace;
    font-weight: 500;
    font-size: 1.0625rem;
    margin: 0;
    letter-spacing: -0.01em;
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
  }
  .block__number {
    color: var(--accent);
    font-weight: 700;
  }
  .block__counter {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.75rem;
    color: var(--fg-subtle);
  }

  .posts {
    width: 100%;
    border-collapse: collapse;
    font-family: "Space Grotesk", sans-serif;
  }
  .posts thead th {
    text-align: left;
    padding: 0.5rem 0.75rem;
    border-bottom: 2px solid var(--border);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-subtle);
    font-weight: 500;
  }
  .post-row td {
    padding: 1rem 0.75rem;
    border-bottom: 1px solid var(--grid);
    vertical-align: top;
  }
  .post-row:last-child td {
    border-bottom: none;
  }
  .post-row:hover {
    background: rgba(226, 59, 45, 0.05);
  }
  .post-row__title {
    font-weight: 600;
    font-size: 1.05rem;
    text-decoration: none;
    color: var(--fg);
    letter-spacing: -0.01em;
    display: block;
    margin-bottom: 0.3rem;
  }
  .post-row:hover .post-row__title {
    color: var(--accent);
  }
  .post-row__description {
    font-size: 0.9rem;
    color: var(--fg-muted);
    margin: 0;
    max-width: 60ch;
  }
  .col-idx {
    width: 3rem;
    font-family: "JetBrains Mono", monospace;
    color: var(--fg-subtle);
  }
  .col-date,
  .col-read {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.8125rem;
    color: var(--fg-muted);
    white-space: nowrap;
  }
  .col-date {
    width: 8rem;
  }
  .col-read {
    width: 4rem;
    text-align: right;
  }

  .talks {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--grid);
  }
  .talk {
    border-bottom: 1px solid var(--grid);
  }
  .talk__link {
    display: grid;
    grid-template-columns: 3rem 1fr auto;
    grid-template-rows: auto auto;
    gap: 0.4rem 1.5rem;
    padding: 1.25rem 0.75rem;
    text-decoration: none;
    color: inherit;
  }
  .talk__link:hover {
    background: rgba(226, 59, 45, 0.05);
  }
  .talk__number {
    font-family: "JetBrains Mono", monospace;
    color: var(--fg-subtle);
  }
  .talk__title {
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
  }
  .talk__meta {
    grid-column: 2 / 3;
    grid-row: 2 / 3;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
    color: var(--fg-muted);
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }
  .talk__cta {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.8rem;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 0.35rem 0.7rem;
    align-self: start;
  }
  .talk__link:hover .talk__cta {
    background: var(--accent);
    color: var(--paper);
  }

  .footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem clamp(1rem, 3vw, 2rem);
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.75rem;
    color: var(--fg-muted);
  }
  .footer a {
    color: var(--accent);
    text-decoration: none;
  }

  @media (max-width: 48rem) {
    .chrome {
      grid-template-columns: 1fr auto;
    }
    .chrome__ruler {
      display: none;
    }
    .posts thead {
      display: none;
    }
    .post-row {
      display: grid;
      grid-template-columns: 1fr;
      padding: 1rem 0.75rem;
      gap: 0.25rem;
      border-bottom: 1px solid var(--grid);
    }
    .post-row td {
      padding: 0;
      border-bottom: none;
    }
    .col-idx {
      display: none;
    }
    .col-date,
    .col-read {
      display: inline;
    }
  }
</style>
