---
import { sample } from "./_sample-data";

const sidenotes = [
  "The 3am rule: if you're being paged for the same alert twice in a week, the alert is wrong before the service is.",
  "Most blogs die at the \"branding\" stage. The cure is a .mdx file and a stubborn refusal to redesign.",
  "Platform teams without product discipline ship internal frameworks. Platform teams with product discipline ship quietly.",
];

const talkNotes = [
  "SRE Next is the closest thing Tokyo has to an annual SRE gathering worth flying in for.",
  "HashiTalks is remote-only; the upside is that the 3am-in-Paris timezone oddly works for lecture-style talks.",
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Tufte — design exploration</title>
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=IBM+Plex+Sans:wght@400;500;600&display=swap"
    />
  </head>
  <body>
    <a href="/design-explorations/" class="back">← all variants</a>

    <article class="essay">
      <header class="masthead">
        <p class="masthead__kicker">an occasional journal · vol. four, no. iii · apr mmxxvi</p>
        <h1 class="masthead__title">Amine Ilidrissi</h1>
        <p class="masthead__subtitle">
          <em>Notes on software, operations, and the long hours between them.</em>
        </p>
        <nav class="masthead__nav">
          <a href="#" aria-current="page">Essays</a>
          <span class="masthead__sep">·</span>
          <a href="#">Talks</a>
          <span class="masthead__sep">·</span>
          <a href="#">Colophon</a>
          <span class="masthead__sep">·</span>
          <a href="#" class="masthead__lang">日本語版</a>
        </nav>
      </header>

      <section class="preamble">
        <p>
          <span class="initial">W</span>riting here is infrequent and
          unhurried. Each piece is accompanied by <a href="#" class="note-ref" data-hover="preamble">marginal commentary</a>
          in the spirit of Tufte — small asides that would interrupt the main
          text but would be missed if cut entirely. If you are reading on a
          narrow screen, the notes collapse into the flow.
        </p>
        <p>
          The catalogue that follows is ordered chronologically, most recent
          first, and lightly annotated.
        </p>
        <aside class="sidenote" data-for="preamble">
          <sup>*</sup> On screens wider than 60em the notes sit to the right
          of the body; below that, they fold inline and become hover-revealed.
        </aside>
      </section>

      <section class="section">
        <h2 class="section__title">
          <span class="section__number">§&thinsp;01</span>
          Essays
        </h2>
        <ol class="entries">
          {sample.posts.map((p, i) => (
            <li class="entry">
              <a href="#" class="entry__link">
                <p class="entry__meta">
                  <span class="entry__date">{p.date}</span>
                  <span class="entry__divider" aria-hidden="true">·</span>
                  <span class="entry__length">{p.read} read</span>
                </p>
                <h3 class="entry__title">
                  {p.title}
                  <a href="#" class="note-ref" data-hover={`essay-${i}`} aria-label="Show sidenote">
                    <sup>{i + 1}</sup>
                  </a>
                </h3>
                <p class="entry__description">{p.description}</p>
              </a>
              <aside class="sidenote" data-for={`essay-${i}`}>
                <sup>{i + 1}</sup> {sidenotes[i] ?? sidenotes[0]}
              </aside>
            </li>
          ))}
        </ol>
      </section>

      <section class="section">
        <h2 class="section__title">
          <span class="section__number">§&thinsp;02</span>
          Talks
        </h2>
        <ol class="entries">
          {sample.talks.map((t, i) => (
            <li class="entry">
              <a href="#" class="entry__link">
                <p class="entry__meta">
                  <span class="entry__date">{t.date}</span>
                  <span class="entry__divider" aria-hidden="true">·</span>
                  <span class="entry__length entry__length--caps">{t.event}, {t.venue}</span>
                </p>
                <h3 class="entry__title">
                  {t.title}
                  <a href="#" class="note-ref" data-hover={`talk-${i}`}>
                    <sup>{i + 1 + sample.posts.length}</sup>
                  </a>
                </h3>
              </a>
              <aside class="sidenote" data-for={`talk-${i}`}>
                <sup>{i + 1 + sample.posts.length}</sup> {talkNotes[i]}
              </aside>
            </li>
          ))}
        </ol>
      </section>

      <footer class="colophon">
        <p>
          Set in <span class="caps">EB Garamond</span> with text figures and
          small capitals, with <span class="caps">IBM Plex Sans</span> for
          department heads. Composed in Astro, published as static HTML.
        </p>
        <p>— <a href="/design-explorations/">Return to the table of variants</a></p>
      </footer>
    </article>
  </body>
</html>

<style is:global>
  :root {
    --bg: #fdf9f0;
    --fg: #161311;
    --fg-muted: #5a524a;
    --fg-subtle: #8f857b;
    --rule: #c9bfad;
    --ref: #7a1a1a;
    --highlight: rgba(237, 214, 157, 0.55);
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; }
  body {
    background: var(--bg);
    color: var(--fg);
    font-family: "EB Garamond", "Source Serif 4", ui-serif, Georgia, serif;
    font-size: 19px;
    line-height: 1.6;
    font-variant-numeric: oldstyle-nums;
    font-feature-settings: "onum", "kern", "liga", "calt";
    text-rendering: optimizeLegibility;
  }
  a { color: inherit; }

  .back {
    position: fixed;
    top: 1rem;
    left: 1rem;
    font-family: "IBM Plex Sans", sans-serif;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-muted);
    text-decoration: none;
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--rule);
    background: var(--bg);
    z-index: 10;
  }
  .back:hover { color: var(--ref); border-color: var(--ref); }

  /* Tufte-like two-column layout: narrow body + wide right sidenote margin. */
  .essay {
    max-width: 60rem;
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) clamp(1.25rem, 4vw, 2rem) 4rem;
  }
  @media (min-width: 62.01rem) {
    .essay { max-width: 60rem; padding-right: 22rem; position: relative; }
  }

  .masthead { padding-bottom: 2rem; border-bottom: 1px solid var(--rule); margin-bottom: 2rem; }
  .masthead__kicker {
    font-family: "IBM Plex Sans", sans-serif;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--fg-subtle);
    margin: 0 0 1rem;
  }
  .masthead__title {
    font-family: "EB Garamond", serif;
    font-weight: 500;
    font-style: italic;
    font-size: clamp(2.75rem, 6vw, 4.5rem);
    letter-spacing: -0.01em;
    line-height: 0.95;
    margin: 0 0 0.75rem;
  }
  .masthead__subtitle {
    font-size: 1.25rem;
    color: var(--fg-muted);
    max-width: 34ch;
    margin: 0 0 1.5rem;
  }
  .masthead__nav {
    font-family: "IBM Plex Sans", sans-serif;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--fg-muted);
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: baseline;
  }
  .masthead__nav a {
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 0.1rem;
    transition: border-color 160ms, color 160ms;
  }
  .masthead__nav a:hover { color: var(--fg); border-bottom-color: var(--fg); }
  .masthead__nav a[aria-current="page"] { color: var(--fg); border-bottom-color: var(--ref); }
  .masthead__sep { color: var(--fg-subtle); }
  .masthead__lang { font-family: "EB Garamond", serif; font-style: italic; text-transform: none; letter-spacing: 0; }

  .preamble { position: relative; }
  .preamble p { max-width: 32rem; margin: 0 0 1rem; }
  .initial {
    float: left;
    font-family: "EB Garamond", serif;
    font-size: 3.25em;
    line-height: 0.85;
    padding-right: 0.12em;
    color: var(--fg);
    font-weight: 500;
  }

  .section {
    margin-top: 3rem;
    position: relative;
  }
  .section__title {
    font-family: "EB Garamond", serif;
    font-style: italic;
    font-weight: 500;
    font-size: 1.5rem;
    letter-spacing: 0;
    margin: 0 0 1.25rem;
    color: var(--fg);
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 0.5rem;
  }
  .section__number {
    font-family: "IBM Plex Sans", sans-serif;
    font-style: normal;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    padding-top: 0.2rem;
  }

  .entries { list-style: none; margin: 0; padding: 0; position: relative; }
  .entry {
    position: relative;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--rule);
  }
  .entry:last-child { border-bottom: none; }
  .entry__link {
    display: block;
    text-decoration: none;
    color: inherit;
    position: relative;
    padding-right: 1.5rem;
  }
  .entry__link::after {
    content: "§";
    position: absolute;
    right: 0;
    top: 1.25rem;
    font-family: "EB Garamond", serif;
    font-size: 1.1rem;
    color: var(--fg-subtle);
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 200ms, transform 200ms, color 200ms;
  }
  .entry__link:hover::after { opacity: 1; transform: translateX(0); color: var(--ref); }
  .entry__meta {
    font-family: "IBM Plex Sans", sans-serif;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--fg-subtle);
    margin: 0 0 0.45rem;
    display: flex;
    gap: 0.55rem;
    flex-wrap: wrap;
  }
  .entry__length--caps { font-variant: small-caps; letter-spacing: 0.08em; }
  .entry__divider { opacity: 0.6; }
  .entry__title {
    font-family: "EB Garamond", serif;
    font-weight: 500;
    font-size: clamp(1.4rem, 3vw, 1.875rem);
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin: 0 0 0.45rem;
  }
  .entry__link:hover .entry__title {
    background-image: linear-gradient(var(--highlight), var(--highlight));
    background-size: 100% 0.3em;
    background-position: 0 85%;
    background-repeat: no-repeat;
  }
  .entry__description {
    font-size: 1.025rem;
    color: var(--fg-muted);
    margin: 0;
    max-width: 44em;
  }

  .note-ref {
    color: var(--ref);
    text-decoration: none;
    margin-left: 0.18em;
  }
  .note-ref:hover { text-decoration: underline; }
  .note-ref sup { font-feature-settings: "sups"; font-size: 0.75em; }

  /* Sidenotes: absolutely positioned to the right of their parent entry
     on wide screens, collapsing to a styled inline aside below ~62rem. */
  .sidenote {
    font-family: "EB Garamond", serif;
    font-style: italic;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--fg-muted);
    padding-left: 1.25rem;
    border-left: 1px solid var(--rule);
    opacity: 0.55;
    transition: opacity 220ms ease, color 220ms ease, border-color 220ms ease;
  }
  .sidenote sup {
    color: var(--ref);
    margin-right: 0.3em;
    font-style: normal;
    font-feature-settings: "sups";
  }

  @media (min-width: 62.01rem) {
    .entry { position: relative; }
    .preamble { position: relative; }
    .sidenote {
      position: absolute;
      left: 100%;
      top: 1.25rem;
      margin-left: 3rem;
      width: 18rem;
    }
    .preamble .sidenote { top: 3.5rem; }
  }

  /* Hover interaction: the entry being hovered brings its sidenote to full. */
  .entry:hover .sidenote,
  .entry:focus-within .sidenote,
  .preamble:hover .sidenote {
    opacity: 1;
    color: var(--fg);
    border-left-color: var(--ref);
  }

  .caps { font-variant: small-caps; letter-spacing: 0.06em; }

  .colophon {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
    font-size: 0.95rem;
    color: var(--fg-muted);
  }
  .colophon p { margin: 0.5rem 0; font-style: italic; }
  .colophon a { color: var(--ref); }

  /* Narrow screens: sidenotes collapse to inline, fully visible. */
  @media (max-width: 62rem) {
    .sidenote {
      font-size: 0.9rem;
      padding: 0.6rem 0.9rem;
      border-left: 2px solid var(--rule);
      margin: 0.75rem 0 0;
      background: rgba(201, 191, 173, 0.15);
      opacity: 1;
      color: var(--fg-muted);
    }
  }
</style>
