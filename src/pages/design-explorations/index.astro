---
// Design exploration index — the shortlist.
const variants = [
  {
    slug: "editorial",
    number: "01",
    name: "Editorial",
    description:
      "Serif body, warm neutral palette, spacious short line-lengths, borderless text-forward cards.",
    keywords: ["Fraunces", "cream + oxblood", "still motion", "text-forward"],
  },
  {
    slug: "brutalist",
    number: "02",
    name: "Brutalist dev",
    description:
      "Monospace for meta and headings, grotesque sans for body. Strict grid, sharp corners, monochrome with one intense accent.",
    keywords: ["JetBrains Mono", "monochrome + red", "info-dense", "no hero"],
  },
  {
    slug: "terminal",
    number: "03",
    name: "Terminal",
    description:
      "Dark monospace CLI aesthetic with a vim-style status bar. Full-row cursor highlight slides in from the left on hover.",
    keywords: ["IBM Plex Mono", "amber on ink", "vim status bar", "row cursor"],
  },
  {
    slug: "tufte",
    number: "04",
    name: "Tufte",
    description:
      "A narrow serif column with hover-revealed sidenotes floated into the right margin. Old-style figures, small caps, near-zero chrome.",
    keywords: ["EB Garamond", "ink on cream", "margin sidenotes", "academic"],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Design explorations — aminevg blog</title>
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <style>
      :root {
        color-scheme: light;
        --fg: #1a1512;
        --fg-muted: #6b635a;
        --fg-subtle: #958c7f;
        --bg: #f7f4ee;
        --surface: #ede4d7;
        --border: #d9ccb7;
        --accent: #7b2d26;
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--fg);
        font-family: "Fraunces", ui-serif, Georgia, serif;
        line-height: 1.55;
      }
      .page {
        max-width: 58rem;
        margin: 0 auto;
        padding: clamp(3rem, 7vw, 5rem) clamp(1.25rem, 4vw, 2.5rem);
      }
      .eyebrow {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.72rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--fg-muted);
        margin: 0 0 1rem;
      }
      h1 {
        font-family: "Fraunces", ui-serif, serif;
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 400;
        font-variation-settings: "SOFT" 40;
        letter-spacing: -0.025em;
        line-height: 1.08;
        margin: 0 0 1rem;
        max-width: 22ch;
      }
      .lede {
        font-size: 1.125rem;
        color: var(--fg-muted);
        max-width: 48ch;
        margin: 0 0 2rem;
      }
      ol.variants {
        list-style: none;
        margin: 2rem 0 0;
        padding: 0;
        border-top: 1px solid var(--border);
      }
      .variant {
        padding: 1.75rem 0;
        border-bottom: 1px solid var(--border);
      }
      .variant__link {
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 1.5rem;
        align-items: baseline;
        text-decoration: none;
        color: inherit;
      }
      .variant__number {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.78rem;
        color: var(--fg-subtle);
        letter-spacing: 0.05em;
        padding-top: 0.35rem;
      }
      .variant__name {
        font-family: "Fraunces", serif;
        font-size: 1.5rem;
        font-weight: 500;
        letter-spacing: -0.015em;
        margin: 0 0 0.45rem;
        transition: color 160ms ease;
      }
      .variant__link:hover .variant__name {
        color: var(--accent);
      }
      .variant__description {
        font-size: 1rem;
        color: var(--fg-muted);
        margin: 0 0 0.65rem;
        max-width: 62ch;
      }
      .variant__keywords {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .variant__keywords li {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.72rem;
        padding: 0.1rem 0.5rem;
        border: 1px solid var(--border);
        border-radius: 999px;
        color: var(--fg-muted);
      }
      .variant__arrow {
        font-family: "JetBrains Mono", monospace;
        color: var(--fg-muted);
        font-size: 1.1rem;
        align-self: center;
        transition:
          transform 160ms ease,
          color 160ms ease;
      }
      .variant__link:hover .variant__arrow {
        transform: translateX(4px);
        color: var(--accent);
      }
      .footnote {
        margin-top: 3rem;
        font-family: "JetBrains Mono", monospace;
        font-size: 0.78rem;
        color: var(--fg-muted);
        max-width: 52ch;
        line-height: 1.65;
      }
      .footnote a {
        color: var(--accent);
      }
    </style>
  </head>
  <body>
    <main class="page">
      <p class="eyebrow">Design exploration · shortlist</p>
      <h1>Four directions on the table.</h1>
      <p class="lede">
        The shortlist after two rounds. All four share the same aesthetic
        gravity — restrained, typographically-led, built for reading — and
        differ in chrome, tone, and what they do when you hover.
      </p>

      <ol class="variants">
        {
          variants.map((v) => (
            <li class="variant">
              <a href={`/design-explorations/${v.slug}/`} class="variant__link">
                <span class="variant__number">{v.number}</span>
                <div>
                  <h2 class="variant__name">{v.name}</h2>
                  <p class="variant__description">{v.description}</p>
                  <ul class="variant__keywords">
                    {v.keywords.map((kw) => (
                      <li>{kw}</li>
                    ))}
                  </ul>
                </div>
                <span class="variant__arrow" aria-hidden="true">
                  →
                </span>
              </a>
            </li>
          ))
        }
      </ol>

      <p class="footnote">
        All variants share the same infrastructure: Astro 6 static output,
        Tailwind 4 tokens, MDX content collections, auto-fetched talk
        thumbnails, native view transitions, and per-locale RSS and llms.txt.
        Only the visual layer differs. See <a href="/en/"
          >the live (Editorial) site</a
        >.
      </p>
    </main>
  </body>
</html>
