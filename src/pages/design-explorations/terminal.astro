---
import { sample } from "./_sample-data";

const nav = [
  { key: "b", label: "blog", current: true },
  { key: "t", label: "talks", current: false },
  { key: "a", label: "about", current: false },
  { key: "r", label: "rss", current: false },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>terminal — design exploration</title>
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap"
    />
  </head>
  <body>
    <a href="/design-explorations/" class="back">◂ all variants</a>

    <div class="crt" aria-hidden="true"></div>

    <main class="term">
      <section class="hero">
        <div class="hero__prompt">
          <span class="hero__user">amine</span><span class="hero__at">@</span
          ><span class="hero__host">tokyo</span>
          <span class="hero__sep">:</span>
          <span class="hero__path">~/blog</span>
          <span class="hero__dollar">$</span>
          <span class="hero__cmd">cat README.md</span>
        </div>
        <pre
          class="hero__out"><code>{`# ${sample.tagline.title.toLowerCase()}

${sample.tagline.subtitle}

`}<span class="hero__dim">[lang]</span>{`   en / ja
`}<span class="hero__dim">[author]</span>{` amine ilidrissi
`}<span class="hero__dim">[since]</span>{`  2020
`}<span class="hero__dim">[stack]</span>{`  astro · mdx · cloudflare`}</code></pre>
        <div class="hero__cursor-line">
          <span class="hero__dollar">$</span>
          <span class="hero__cursor">█</span>
        </div>
      </section>

      <nav class="nav">
        <span class="nav__label">nav:</span>
        {
          nav.map((n) => (
            <a
              href="#"
              class={`nav__item ${n.current ? "nav__item--current" : ""}`}
            >
              <span class="nav__key">[{n.key}]</span>
              <span class="nav__word">{n.label}</span>
            </a>
          ))
        }
        <span class="nav__flex"></span>
        <span class="nav__meta"><span class="nav__key">[g]</span> 日本語</span>
      </nav>

      <section class="block">
        <header class="block__head">
          <span class="block__glyph" aria-hidden="true">▸</span>
          <h2>posts ({String(sample.posts.length).padStart(2, "0")})</h2>
          <span class="block__rule" aria-hidden="true"></span>
          <a href="#" class="block__all">view all →</a>
        </header>
        <ul class="rows">
          {
            sample.posts.map((p, i) => (
              <li class="row">
                <a href="#" class="row__link">
                  <span class="row__idx">{String(i + 1).padStart(2, "0")}</span>
                  <span class="row__date">{p.date.replace(/,/g, "")}</span>
                  <span class="row__title">{p.title}</span>
                  <span class="row__read">{p.read}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="block">
        <header class="block__head">
          <span class="block__glyph" aria-hidden="true">▸</span>
          <h2>talks ({String(sample.talks.length).padStart(2, "0")})</h2>
          <span class="block__rule" aria-hidden="true"></span>
          <a href="#" class="block__all">view all →</a>
        </header>
        <ul class="rows">
          {
            sample.talks.map((t, i) => (
              <li class="row">
                <a href="#" class="row__link">
                  <span class="row__idx">{String(i + 1).padStart(2, "0")}</span>
                  <span class="row__date">{t.date.replace(" ", "-")}</span>
                  <span class="row__title">
                    {t.title} <span class="row__ext">— {t.event}</span>
                  </span>
                  <span class="row__read">↗</span>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </main>

    <footer class="status" role="contentinfo">
      <div class="status__left">
        <span class="status__mode">NORMAL</span>
        <span class="status__file">~/blog/index.mdx</span>
        <span class="status__branch">⌥ main</span>
      </div>
      <div class="status__right">
        <span class="status__pos">21,3</span>
        <span class="status__pct">100%</span>
        <span class="status__variant"
          ><a href="/design-explorations/">⚙ variant</a></span
        >
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0c0d10;
    --bg-alt: #14161b;
    --fg: #d4d4d0;
    --fg-dim: #7b7e85;
    --fg-faint: #4a4c52;
    --accent: #e6c275;
    --accent-2: #73c991;
    --accent-3: #e18285;
    --row-hover: rgba(230, 194, 117, 0.06);
    --row-bar: rgba(230, 194, 117, 0.9);
  }
  * {
    box-sizing: border-box;
  }
  html,
  body {
    margin: 0;
  }
  body {
    background: var(--bg);
    color: var(--fg);
    font-family: "IBM Plex Mono", ui-monospace, Menlo, monospace;
    font-size: 14px;
    line-height: 1.65;
    min-height: 100vh;
    padding-bottom: 3rem;
    letter-spacing: 0.005em;
  }
  a {
    color: inherit;
  }

  .back {
    position: fixed;
    top: 1rem;
    left: 1rem;
    font-size: 0.7rem;
    color: var(--fg-dim);
    text-decoration: none;
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--fg-faint);
    background: var(--bg-alt);
    z-index: 10;
    letter-spacing: 0.05em;
  }
  .back:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* Subtle CRT overlay — thin scanlines and corner vignette. */
  .crt {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 5;
    background:
      radial-gradient(
        ellipse at center,
        transparent 55%,
        rgba(0, 0, 0, 0.45) 100%
      ),
      repeating-linear-gradient(
        0deg,
        rgba(255, 255, 255, 0.015) 0,
        rgba(255, 255, 255, 0.015) 1px,
        transparent 1px,
        transparent 3px
      );
    mix-blend-mode: overlay;
  }
  @media (prefers-reduced-motion: reduce) {
    .crt {
      display: none;
    }
  }

  .term {
    max-width: 58rem;
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 4.5rem) clamp(1rem, 3vw, 2rem) 5rem;
    position: relative;
    z-index: 1;
  }

  .hero {
    margin-bottom: 3rem;
  }
  .hero__prompt {
    font-weight: 500;
    margin-bottom: 0.75rem;
  }
  .hero__user {
    color: var(--accent-2);
  }
  .hero__at {
    color: var(--fg-dim);
  }
  .hero__host {
    color: var(--accent);
  }
  .hero__sep {
    color: var(--fg-dim);
  }
  .hero__path {
    color: var(--accent-3);
  }
  .hero__dollar {
    color: var(--fg-dim);
    margin: 0 0.4rem;
  }
  .hero__cmd {
    color: var(--fg);
  }

  .hero__out {
    margin: 0 0 0.5rem;
    font-family: inherit;
    font-size: clamp(0.875rem, 1.6vw, 1rem);
    line-height: 1.75;
    white-space: pre-wrap;
    color: var(--fg);
  }
  .hero__out {
    color: var(--fg);
  }
  .hero__dim {
    color: var(--fg-dim);
  }

  .hero__cursor-line {
    display: flex;
    align-items: center;
  }
  .hero__cursor {
    display: inline-block;
    color: var(--accent);
    animation: blink 1.1s steps(1, end) infinite;
    font-weight: 500;
  }
  @keyframes blink {
    50% {
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__cursor {
      animation: none;
    }
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    border-top: 1px dashed var(--fg-faint);
    border-bottom: 1px dashed var(--fg-faint);
    padding: 0.625rem 0;
    margin: 2.5rem 0 2rem;
    font-size: 0.8125rem;
    flex-wrap: wrap;
  }
  .nav__label {
    color: var(--fg-dim);
  }
  .nav__item {
    text-decoration: none;
    color: var(--fg-dim);
    display: inline-flex;
    align-items: baseline;
    gap: 0.3rem;
    padding: 0.1rem 0;
    border-bottom: 1px solid transparent;
    transition:
      color 160ms ease,
      border-color 160ms ease;
  }
  .nav__item:hover {
    color: var(--fg);
  }
  .nav__item--current {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .nav__key {
    color: var(--accent);
    font-weight: 500;
  }
  .nav__flex {
    flex: 1;
  }
  .nav__meta {
    color: var(--fg-dim);
    font-size: 0.78rem;
  }

  .block {
    margin-bottom: 2.5rem;
  }
  .block__head {
    display: grid;
    grid-template-columns: auto auto 1fr auto;
    gap: 0.75rem;
    align-items: center;
    margin-bottom: 1rem;
  }
  .block__glyph {
    color: var(--accent);
  }
  .block__head h2 {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--fg);
    letter-spacing: 0.02em;
  }
  .block__rule {
    border-top: 1px dashed var(--fg-faint);
    height: 0;
  }
  .block__all {
    font-size: 0.78rem;
    color: var(--fg-dim);
    text-decoration: none;
  }
  .block__all:hover {
    color: var(--accent);
  }

  .rows {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .row {
    position: relative;
  }
  /* Full-row cursor highlight on hover — the signature interaction. */
  .row__link {
    display: grid;
    grid-template-columns: 2.5rem 7rem 1fr auto;
    align-items: baseline;
    gap: 1rem;
    padding: 0.5rem 0.75rem;
    margin: 0 -0.75rem;
    text-decoration: none;
    color: inherit;
    position: relative;
    transition:
      background 180ms ease,
      color 180ms ease;
  }
  .row__link::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: transparent;
    transition:
      background 180ms ease,
      transform 180ms ease;
    transform: scaleY(0.3);
    transform-origin: center;
  }
  .row__link:hover {
    background: var(--row-hover);
    color: var(--fg);
  }
  .row__link:hover::before {
    background: var(--row-bar);
    transform: scaleY(1);
  }
  .row__link::after {
    content: "▸";
    position: absolute;
    right: 0.75rem;
    color: var(--accent);
    opacity: 0;
    transform: translateX(-6px);
    transition:
      opacity 180ms ease,
      transform 180ms ease;
    pointer-events: none;
  }
  .row__link:hover::after {
    opacity: 0;
  }
  .row__idx {
    color: var(--fg-faint);
    font-variant-numeric: tabular-nums;
  }
  .row__date {
    color: var(--fg-dim);
    font-size: 0.78rem;
    font-variant-numeric: tabular-nums;
  }
  .row__title {
    color: var(--fg);
    font-weight: 500;
  }
  .row__ext {
    color: var(--fg-dim);
    font-weight: 400;
  }
  .row__read {
    color: var(--fg-dim);
    font-size: 0.78rem;
    text-align: right;
  }
  .row__link:hover .row__title {
    color: var(--accent);
  }

  @media (max-width: 42rem) {
    .row__link {
      grid-template-columns: 2rem 1fr auto;
    }
    .row__date {
      display: none;
    }
  }

  .status {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.35rem 1rem;
    background: #1e2027;
    color: var(--fg-dim);
    font-size: 0.75rem;
    z-index: 6;
    border-top: 1px solid var(--fg-faint);
  }
  .status__left,
  .status__right {
    display: flex;
    gap: 1rem;
    align-items: center;
  }
  .status__mode {
    background: var(--accent);
    color: #1a1a1a;
    padding: 0 0.5rem;
    font-weight: 600;
    letter-spacing: 0.1em;
  }
  .status__file {
    color: var(--fg);
  }
  .status__branch {
    color: var(--accent-2);
  }
  .status__variant a {
    color: var(--accent-3);
    text-decoration: none;
  }
  .status__variant a:hover {
    text-decoration: underline;
  }
  @media (max-width: 42rem) {
    .status__file,
    .status__pos,
    .status__pct {
      display: none;
    }
  }
</style>
