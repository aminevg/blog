---
import type { GetStaticPaths } from "astro";
import BaseLayout from "~/layouts/BaseLayout.astro";
import FormattedDate from "~/components/ui/FormattedDate.astro";
import { SITE } from "~/config/site";
import type { Locale } from "~/config/site";
import { t } from "~/i18n/ui";
import { getTalks } from "~/lib/content";
import { localeTalks } from "~/lib/paths";

export const getStaticPaths: GetStaticPaths = async () => {
  return SITE.locales.map((lang) => ({ params: { lang } }));
};

const { lang } = Astro.params;
const locale = lang as Locale;
const otherLocale: Locale = locale === "en" ? "ja" : "en";
const strings = t(locale);

const talks = await getTalks(locale);
const otherHref = localeTalks(otherLocale);

function paragraphs(text: string): string[] {
  return text
    .split(/\n{2,}/)
    .map((p) => p.replace(/\s+/g, " ").trim())
    .filter(Boolean);
}
---

<BaseLayout
  locale={locale}
  title={strings.listings.talksTitle}
  description={strings.listings.talksDescription}
  alternateUrl={otherHref}
  xDefaultUrl={localeTalks("en")}
  ogImage={`/open-graph/${locale}/talks.png`}
>
  <section class="listing">
    <h2 class="listing__title">{strings.listings.talksTitle}</h2>
    <ol class="entries">
      {
        talks.map((entry) => {
          const {
            title,
            abstract,
            event,
            eventDate,
            venue,
            slidesUrl,
            videoUrl,
          } = entry.data;
          return (
            <li class="entry">
              <a
                href={slidesUrl}
                class="entry__link"
                target="_blank"
                rel="noopener"
                aria-label={title}
              >
                <p class="entry__meta">
                  <span>{event}</span>
                  {venue && (
                    <>
                      <span aria-hidden="true"> · </span>
                      <span>{venue}</span>
                    </>
                  )}
                  <span aria-hidden="true"> · </span>
                  <FormattedDate date={eventDate} locale={locale} />
                </p>
                <h3 class="entry__title">{title}</h3>
                <div class="entry__abstract">
                  {paragraphs(abstract).map((p) => (
                    <p>{p}</p>
                  ))}
                </div>
                <p class="entry__action">
                  {strings.talk.viewSlides} <span aria-hidden="true">↗</span>
                </p>
              </a>
              {videoUrl && (
                <p class="entry__recording">
                  <a href={videoUrl} target="_blank" rel="noopener">
                    {strings.talk.watchRecording}{" "}
                    <span aria-hidden="true">↗</span>
                  </a>
                </p>
              )}
            </li>
          );
        })
      }
    </ol>
  </section>
</BaseLayout>

<style>
  .listing__title {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 500;
    font-size: 1.5rem;
    margin: 0 0 1.25rem;
    color: var(--color-fg);
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: 0.5rem;
  }

  .entries {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .entry {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-rule);
  }

  .entry:last-child {
    border-bottom: none;
  }

  .entry__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .entry__meta {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-fg-subtle);
    margin: 0 0 0.45rem;
  }

  .entry__title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(1.4rem, 3vw, 1.875rem);
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin: 0 0 0.6rem;
    color: var(--color-fg);
  }

  .entry__link:hover .entry__title {
    background-image: linear-gradient(
      var(--color-highlight),
      var(--color-highlight)
    );
    background-size: 100% 0.3em;
    background-position: 0 85%;
    background-repeat: no-repeat;
  }

  .entry__abstract {
    color: var(--color-fg-muted);
    max-width: 44em;
  }

  .entry__abstract p {
    margin: 0 0 0.75rem;
    font-size: 1.025rem;
    line-height: 1.55;
  }

  .entry__abstract p:last-child {
    margin-bottom: 0;
  }

  .entry__action {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-accent);
    margin: 0.75rem 0 0;
  }

  .entry__recording {
    margin: 0.5rem 0 0;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .entry__recording a {
    color: var(--color-fg-muted);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 0.1rem;
    transition:
      color 160ms,
      border-color 160ms;
  }

  .entry__recording a:hover {
    color: var(--color-fg);
    border-bottom-color: var(--color-fg);
  }
</style>
