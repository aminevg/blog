---
import type { GetStaticPaths } from "astro";
import BaseLayout from "~/layouts/BaseLayout.astro";
import FormattedDate from "~/components/ui/FormattedDate.astro";
import CardLink from "~/components/ui/CardLink.astro";
import { SITE } from "~/config/site";
import type { Locale } from "~/config/site";
import { t, otherLocale } from "~/i18n/ui";
import { getTalks } from "~/lib/content";
import { localeTalks } from "~/lib/paths";

export const getStaticPaths: GetStaticPaths = async () => {
  return SITE.locales.map((lang) => ({ params: { lang } }));
};

const { lang } = Astro.params;
const locale = lang as Locale;
const strings = t(locale);

const talks = await getTalks(locale);
const otherHref = localeTalks(otherLocale(locale));
---

<BaseLayout
  locale={locale}
  title={strings.listings.talksTitle}
  description={strings.listings.talksDescription}
  alternateUrl={otherHref}
  xDefaultUrl={localeTalks("en")}
  ogImage={`/open-graph/${locale}/talks.png`}
>
  <section>
    <h1
      class="text-ink border-rule mb-5 border-b pb-2 font-serif text-2xl font-medium italic"
    >
      {strings.listings.talksTitle}
    </h1>
    <ol class="m-0 list-none p-0">
      {
        talks.map((entry) => {
          const { title, description, event, eventDate, venue, slidesUrl } =
            entry.data;
          return (
            <li class="border-rule border-b py-6 last:border-b-0">
              <CardLink
                href={slidesUrl}
                target="_blank"
                rel="noopener"
                aria-label={title}
              >
                <p slot="meta" class="text-ink-subtle kicker mb-[0.45rem]">
                  <span>{event}</span>
                  {venue && (
                    <>
                      <span aria-hidden="true"> · </span>
                      <span>{venue}</span>
                    </>
                  )}
                  <span aria-hidden="true"> · </span>
                  <FormattedDate date={eventDate} locale={locale} />
                </p>
                <Fragment slot="title">{title}</Fragment>
                <p
                  slot="content"
                  class="text-ink-muted m-0 max-w-[44em] text-[1.025rem]"
                >
                  {description}
                </p>
              </CardLink>
            </li>
          );
        })
      }
    </ol>
  </section>
</BaseLayout>
