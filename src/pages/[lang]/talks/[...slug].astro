---
import type { GetStaticPaths } from "astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "~/layouts/BaseLayout.astro";
import FormattedDate from "~/components/ui/FormattedDate.astro";
import type { Locale } from "~/config/site";
import { t } from "~/i18n/ui";
import { talkSlug, talkExists, type TalkEntry } from "~/lib/content";
import { talkUrl } from "~/lib/paths";

export const getStaticPaths: GetStaticPaths = async () => {
  const talks = await getCollection("talks");
  return talks.map((entry) => ({
    params: { lang: entry.data.lang, slug: talkSlug(entry) },
    props: { entry },
  }));
};

interface Props {
  entry: TalkEntry;
}

const { entry } = Astro.props as unknown as Props;
const locale = entry.data.lang as Locale;
const otherLocale: Locale = locale === "en" ? "ja" : "en";
const slug = talkSlug(entry);
const strings = t(locale);

const otherHref = (await talkExists(otherLocale, slug)) ? talkUrl(otherLocale, slug) : null;
const xDefault = (await talkExists("en", slug)) ? talkUrl("en", slug) : undefined;

const { Content } = await render(entry);
const { title, description, event, eventDate, venue, slidesUrl, videoUrl, thumbnail } = entry.data;
const transitionName = `thumb-talk-${slug}`;
---
<BaseLayout
  locale={locale}
  title={title}
  description={description}
  alternateUrl={otherHref}
  xDefaultUrl={xDefault}
  ogImage={`/open-graph/${locale}/talks/${slug}.png`}
>
  <article class="talk prose">
    <header class="talk__header">
      <p class="talk__event">
        <span>{event}</span>
        {venue && <span class="talk__sep"> · {venue}</span>}
        <span class="talk__sep"> · </span>
        <FormattedDate date={eventDate} locale={locale} />
      </p>
      <h1>{title}</h1>
      <p class="talk__description">{description}</p>
    </header>

    {thumbnail && (
      <div class="talk__hero" style={`view-transition-name: ${transitionName}`}>
        <Image
          src={thumbnail}
          alt=""
          widths={[640, 1024, 1536]}
          sizes="(min-width: 48rem) 42rem, 100vw"
          loading="eager"
          decoding="async"
        />
      </div>
    )}

    <div class="talk__actions">
      <a
        href={slidesUrl}
        class="talk__button talk__button--primary"
        target="_blank"
        rel="noopener noreferrer"
      >
        {strings.talk.viewSlides} <span aria-hidden="true">↗</span>
      </a>
      {videoUrl && (
        <a
          href={videoUrl}
          class="talk__button"
          target="_blank"
          rel="noopener noreferrer"
        >
          {strings.talk.watchRecording} <span aria-hidden="true">↗</span>
        </a>
      )}
    </div>

    <div class="talk__body">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .talk__header {
    margin-bottom: 2rem;
  }

  .talk__event {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-fg-muted);
    letter-spacing: 0.02em;
    margin: 0 0 0.5rem;
    text-transform: uppercase;
  }

  .talk__description {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.55;
    color: var(--color-fg-muted);
    margin: 1rem 0 0;
    max-width: 52ch;
  }

  .talk__hero {
    margin: 0 0 2rem;
    border-radius: 0.5rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .talk__hero :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  .talk__actions {
    display: flex;
    gap: 0.75rem;
    margin: 0 0 3rem;
    flex-wrap: wrap;
  }

  .talk__button {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    padding: 0.625rem 1.125rem;
    border-radius: 0.375rem;
    border: 1px solid var(--color-border-strong);
    color: var(--color-fg);
    background: var(--color-surface-raised);
    text-decoration: none;
    transition: border-color 120ms ease, background 120ms ease;
  }

  .talk__button:hover {
    border-color: var(--color-accent);
    background: var(--color-accent-soft);
  }

  .talk__button--primary {
    background: var(--color-accent);
    color: var(--color-bg);
    border-color: var(--color-accent);
  }

  .talk__button--primary:hover {
    background: var(--color-accent-strong);
    border-color: var(--color-accent-strong);
  }
</style>
