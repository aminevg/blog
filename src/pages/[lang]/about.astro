---
import type { GetStaticPaths } from "astro";
import { getEntry, render } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import { SITE } from "~/config/site";
import type { Locale } from "~/config/site";
import { localeAbout } from "~/lib/paths";

export const getStaticPaths: GetStaticPaths = async () => {
  return SITE.locales.map((lang) => ({ params: { lang } }));
};

const { lang } = Astro.params;
const locale = lang as Locale;
const otherLocale: Locale = locale === "en" ? "ja" : "en";

const entry = await getEntry("pages", `about/${locale}`);
if (!entry) {
  throw new Error(`Missing about entry for locale ${locale}`);
}

const otherEntry = await getEntry("pages", `about/${otherLocale}`);
const otherHref = otherEntry ? localeAbout(otherLocale) : null;

const { Content } = await render(entry);
---

<BaseLayout
  locale={locale}
  title={entry.data.title}
  description={entry.data.description}
  alternateUrl={otherHref}
  xDefaultUrl={localeAbout("en")}
  ogImage={`/open-graph/${locale}/about.png`}
>
  <article class="prose">
    <header class="prose__header">
      <h1>{entry.data.title}</h1>
    </header>
    <Content />
  </article>
</BaseLayout>

<style is:global>
  .prose {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-fg);
  }

  .prose__header {
    margin-bottom: 2.5rem;
  }

  .prose h1 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2rem, 5vw, 2.75rem);
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--color-fg);
    margin: 0 0 0.5rem;
  }

  .prose h2 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.5rem;
    letter-spacing: -0.015em;
    margin: 2.5rem 0 0.75rem;
    color: var(--color-fg);
  }

  .prose h3 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.2rem;
    margin: 2rem 0 0.5rem;
    color: var(--color-fg);
  }

  .prose p {
    margin: 0 0 1.25rem;
    max-width: 68ch;
  }

  .prose a {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: color-mix(
      in oklab,
      var(--color-accent) 40%,
      transparent
    );
    text-underline-offset: 0.15em;
  }

  .prose a:hover {
    text-decoration-color: var(--color-accent);
  }

  .prose strong {
    font-weight: 600;
    color: var(--color-fg);
  }

  .prose code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--color-surface);
    padding: 0.1em 0.35em;
    border-radius: 0.25em;
    border: 1px solid var(--color-border);
  }

  .prose ul,
  .prose ol {
    margin: 0 0 1.25rem;
    padding-left: 1.25rem;
  }

  .prose li {
    margin-bottom: 0.375rem;
    line-height: 1.6;
  }

  .prose blockquote {
    border-left: 2px solid var(--color-accent);
    padding-left: 1.25rem;
    font-style: italic;
    color: var(--color-fg-muted);
    margin: 1.5rem 0;
  }

  .prose hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 3rem 0;
  }

  .prose img {
    width: 100%;
    height: auto;
    border-radius: 0.375rem;
    margin: 2rem 0;
  }
</style>
