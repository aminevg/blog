---
import type { GetStaticPaths } from "astro";
import { getEntry, render } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import Link from "~/components/ui/Link.astro";
import { SITE } from "~/config/site";
import type { Locale } from "~/config/site";
import { otherLocale } from "~/i18n/ui";
import { localeAbout } from "~/lib/paths";

export const getStaticPaths: GetStaticPaths = async () => {
  return SITE.locales.map((lang) => ({ params: { lang } }));
};

const { lang } = Astro.params;
const locale = lang as Locale;
const other = otherLocale(locale);

const [entry, otherEntry] = await Promise.all([
  getEntry("pages", `about/${locale}`),
  getEntry("pages", `about/${other}`),
]);
if (!entry) {
  throw new Error(`Missing about entry for locale ${locale}`);
}

const otherHref = otherEntry ? localeAbout(other) : null;

const { Content } = await render(entry);
---

<BaseLayout
  locale={locale}
  title={entry.data.title}
  description={entry.data.description}
  alternateUrl={otherHref}
  xDefaultUrl={localeAbout("en")}
  ogImage={`/open-graph/${locale}/about.png`}
>
  <article class="tufte-prose">
    <header class="mb-10">
      <h1
        class="text-standing-title text-ink m-0 font-serif leading-[1.15] font-medium tracking-[-0.01em] italic"
      >
        {entry.data.title}
      </h1>
    </header>
    <Content components={{ a: Link }} />
  </article>
</BaseLayout>
