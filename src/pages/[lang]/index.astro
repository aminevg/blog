---
import type { GetStaticPaths } from "astro";
import BaseLayout from "~/layouts/BaseLayout.astro";
import FormattedDate from "~/components/ui/FormattedDate.astro";
import CardLink from "~/components/ui/CardLink.astro";
import NavLink from "~/components/ui/NavLink.astro";
import { SITE } from "~/config/site";
import type { Locale } from "~/config/site";
import { t, otherLocale } from "~/i18n/ui";
import { getPosts, getTalks, postSlug } from "~/lib/content";
import { localeBlog, localeTalks, localeHome, postUrl } from "~/lib/paths";

export const getStaticPaths: GetStaticPaths = async () => {
  return SITE.locales.map((lang) => ({ params: { lang } }));
};

const { lang } = Astro.params;
const locale = lang as Locale;
const strings = t(locale);

const [allPosts, allTalks] = await Promise.all([
  getPosts(locale),
  getTalks(locale),
]);
const posts = allPosts.slice(0, SITE.home.postsCount);
const talks = allTalks.slice(0, SITE.home.talksCount);

const otherLocaleHref = localeHome(otherLocale(locale));

const preamble =
  locale === "en"
    ? "Writing here is infrequent and unhurried. Each piece is a set of notes I wanted to keep — on running systems in production, on the shape of teams that build platforms, on the long hours between Paris and Tokyo."
    : "ここでの文章は頻度も速度もゆるやかです。プロダクションでシステムを運用するということ、プラットフォームを作るチームのかたち、そしてパリと東京のあいだで過ぎていく長い時間について、手元に残しておきたかったメモを置いています。";

const sectionTitle =
  "text-ink border-rule mb-5 border-b pb-2 font-serif text-2xl font-medium italic";
const entryMeta = "text-ink-subtle kicker mb-[0.45rem]";
const entryDescription = "text-ink-muted m-0 max-w-[44em] text-[1.025rem]";
---

<BaseLayout
  locale={locale}
  title={SITE.title}
  description={SITE.description[locale]}
  alternateUrl={otherLocaleHref}
  xDefaultUrl={localeHome("en")}
  ogImage={`/open-graph/${locale}/home.png`}
>
  <h1 class="sr-only">{SITE.title}</h1>
  <section class="mb-12">
    <p class="text-ink-muted m-0 max-w-[32rem] text-[1.125rem]">
      <em>{preamble}</em>
    </p>
  </section>

  {
    posts.length > 0 && (
      <section class="mb-12">
        <p class={sectionTitle}>{strings.home.latestPosts}</p>
        <ol class="m-0 list-none p-0">
          {posts.map((entry) => {
            const slug = postSlug(entry);
            return (
              <li class="border-rule border-b py-5 last:border-b-0">
                <CardLink
                  href={postUrl(locale, slug)}
                  aria-label={entry.data.title}
                >
                  <p slot="meta" class={entryMeta}>
                    <FormattedDate date={entry.data.pubDate} locale={locale} />
                  </p>
                  <Fragment slot="title">{entry.data.title}</Fragment>
                  <p slot="content" class={entryDescription}>
                    {entry.data.description}
                  </p>
                </CardLink>
              </li>
            );
          })}
        </ol>
        <p class="kicker m-0 mt-4">
          <NavLink href={localeBlog(locale)}>
            → {strings.home.viewAllPosts}
          </NavLink>
        </p>
      </section>
    )
  }

  {
    talks.length > 0 && (
      <section class="mb-12">
        <p class={sectionTitle}>{strings.home.latestTalks}</p>
        <ol class="m-0 list-none p-0">
          {talks.map((entry) => {
            const { title, description, event, eventDate, venue, slidesUrl } =
              entry.data;
            return (
              <li class="border-rule border-b py-5 last:border-b-0">
                <CardLink
                  href={slidesUrl}
                  target="_blank"
                  rel="noopener"
                  aria-label={title}
                >
                  <p slot="meta" class={entryMeta}>
                    <span>{event}</span>
                    {venue && (
                      <>
                        <span aria-hidden="true"> · </span>
                        <span>{venue}</span>
                      </>
                    )}
                    <span aria-hidden="true"> · </span>
                    <FormattedDate date={eventDate} locale={locale} />
                  </p>
                  <Fragment slot="title">{title}</Fragment>
                  <p slot="content" class={entryDescription}>
                    {description}
                  </p>
                </CardLink>
              </li>
            );
          })}
        </ol>
        <p class="kicker m-0 mt-4">
          <NavLink href={localeTalks(locale)}>
            → {strings.home.viewAllTalks}
          </NavLink>
        </p>
      </section>
    )
  }
</BaseLayout>
