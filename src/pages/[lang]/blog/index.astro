---
import type { GetStaticPaths } from "astro";
import BaseLayout from "~/layouts/BaseLayout.astro";
import SectionHeader from "~/components/ui/SectionHeader.astro";
import PostCard from "~/components/ui/PostCard.astro";
import { SITE } from "~/config/site";
import type { Locale } from "~/config/site";
import { t } from "~/i18n/ui";
import { getPosts } from "~/lib/content";
import { localeBlog } from "~/lib/paths";

export const getStaticPaths: GetStaticPaths = async () => {
  return SITE.locales.map((lang) => ({ params: { lang } }));
};

const { lang } = Astro.params;
const locale = lang as Locale;
const otherLocale: Locale = locale === "en" ? "ja" : "en";
const strings = t(locale);

const posts = await getPosts(locale);
const otherHref = localeBlog(otherLocale);
---
<BaseLayout
  locale={locale}
  title={strings.listings.postsTitle}
  description={strings.listings.postsDescription}
  alternateUrl={otherHref}
  xDefaultUrl={localeBlog("en")}
>
  <SectionHeader
    title={strings.listings.postsTitle}
    description={strings.listings.postsDescription}
    level={1}
  />
  <div class="blog-listing">
    {posts.map((entry) => <PostCard entry={entry} locale={locale} />)}
  </div>
</BaseLayout>

<style>
  .blog-listing {
    display: flex;
    flex-direction: column;
  }
</style>
