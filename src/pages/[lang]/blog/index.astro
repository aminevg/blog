---
import type { GetStaticPaths } from "astro";
import BaseLayout from "~/layouts/BaseLayout.astro";
import FormattedDate from "~/components/ui/FormattedDate.astro";
import CardLink from "~/components/ui/CardLink.astro";
import { SITE } from "~/config/site";
import type { Locale } from "~/config/site";
import { t, otherLocale } from "~/i18n/ui";
import { getPosts, postSlug } from "~/lib/content";
import { localeBlog, postUrl } from "~/lib/paths";

export const getStaticPaths: GetStaticPaths = async () => {
  return SITE.locales.map((lang) => ({ params: { lang } }));
};

const { lang } = Astro.params;
const locale = lang as Locale;
const strings = t(locale);

const posts = await getPosts(locale);
const otherHref = localeBlog(otherLocale(locale));
---

<BaseLayout
  locale={locale}
  title={strings.listings.postsTitle}
  description={strings.listings.postsDescription}
  alternateUrl={otherHref}
  xDefaultUrl={localeBlog("en")}
  ogImage={`/open-graph/${locale}/blog.png`}
>
  <section>
    <h1
      class="text-ink border-rule mb-5 border-b pb-2 font-serif text-2xl font-medium italic"
    >
      {strings.listings.postsTitle}
    </h1>
    <ol class="m-0 list-none p-0">
      {
        posts.map((entry) => {
          const slug = postSlug(entry);
          return (
            <li class="border-rule border-b py-6 last:border-b-0">
              <CardLink
                href={postUrl(locale, slug)}
                aria-label={entry.data.title}
              >
                <p slot="meta" class="text-ink-subtle kicker mb-[0.45rem]">
                  <FormattedDate date={entry.data.pubDate} locale={locale} />
                </p>
                <Fragment slot="title">{entry.data.title}</Fragment>
                <p
                  slot="content"
                  class="text-ink-muted m-0 max-w-[44em] text-[1.025rem]"
                >
                  {entry.data.description}
                </p>
              </CardLink>
            </li>
          );
        })
      }
    </ol>
  </section>
</BaseLayout>
