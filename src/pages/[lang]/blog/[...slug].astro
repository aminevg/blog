---
import type { GetStaticPaths } from "astro";
import { getCollection, render } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import FormattedDate from "~/components/ui/FormattedDate.astro";
import Link from "~/components/ui/Link.astro";
import type { Locale } from "~/config/site";
import { t, otherLocale } from "~/i18n/ui";
import { postSlug, postExists, type PostEntry } from "~/lib/content";
import { postUrl, localeBlog } from "~/lib/paths";

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection("posts");
  return posts.map((entry) => ({
    params: { lang: entry.data.lang, slug: postSlug(entry) },
    props: { entry },
  }));
};

interface Props {
  entry: PostEntry;
}

const { entry } = Astro.props as unknown as Props;
const locale = entry.data.lang as Locale;
const other = otherLocale(locale);
const slug = postSlug(entry);
const strings = t(locale);

const [otherExists, enExists] = await Promise.all([
  postExists(other, slug),
  postExists("en", slug),
]);
const otherHref = otherExists ? postUrl(other, slug) : null;
const xDefault = enExists ? postUrl("en", slug) : undefined;

const { Content } = await render(entry);
const {
  title,
  description,
  pubDate,
  updatedDate,
  canonicalUrl,
  canonicalSource,
} = entry.data;
---

<BaseLayout
  locale={locale}
  title={title}
  description={description}
  canonical={canonicalUrl}
  alternateUrl={otherHref}
  xDefaultUrl={xDefault}
  ogImage={`/open-graph/${locale}/blog/${slug}.png`}
  article={{ publishedTime: pubDate, modifiedTime: updatedDate }}
>
  <p
    class="mb-6 font-sans text-[0.72rem] font-medium tracking-[0.14em] uppercase"
  >
    <Link
      href={localeBlog(locale)}
      class="text-ink-muted hover:text-oxblood hover:border-oxblood border-b border-transparent pb-[0.1rem] no-underline transition-colors duration-150"
      >← {strings.post.backToBlog}</Link
    >
  </p>

  <article class="relative [counter-reset:sidenote]">
    <header class="mb-8">
      <p
        class="text-ink-subtle mb-3 font-sans text-[0.72rem] font-medium tracking-[0.14em] uppercase"
      >
        <FormattedDate date={pubDate} locale={locale} />
      </p>
      <h1
        class="text-display text-ink mb-4 font-serif leading-[1.05] font-medium tracking-[-0.01em] italic"
      >
        {title}
      </h1>
      <p
        class="text-ink-muted m-0 max-w-[44em] font-serif text-xl leading-[1.5]"
      >
        {description}
      </p>
    </header>

    <div class="tufte-prose relative max-w-[32rem]">
      <Content components={{ a: Link }} />
    </div>

    <footer
      class="border-rule text-ink-muted mt-12 max-w-[32rem] border-t pt-5 font-serif text-[0.95rem] italic"
    >
      {
        updatedDate && (
          <p class="my-[0.35rem]">
            {strings.post.updated}{" "}
            <FormattedDate date={updatedDate} locale={locale} />
          </p>
        )
      }
      {
        canonicalUrl && (
          <p class="my-[0.35rem]">
            {strings.post.firstPublishedOn}{" "}
            <Link
              href={canonicalUrl.toString()}
              rel="canonical"
              class="decoration-rule hover:decoration-oxblood hover:text-oxblood underline"
            >
              {canonicalSource ?? new URL(canonicalUrl.toString()).host}{" "}
              <span aria-hidden="true">↗</span>
            </Link>
          </p>
        )
      }
    </footer>
  </article>
</BaseLayout>
