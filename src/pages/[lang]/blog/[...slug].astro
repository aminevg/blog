---
import type { GetStaticPaths } from "astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "~/layouts/BaseLayout.astro";
import FormattedDate from "~/components/ui/FormattedDate.astro";
import type { Locale } from "~/config/site";
import { t } from "~/i18n/ui";
import { postSlug, postExists, type PostEntry } from "~/lib/content";
import { postUrl } from "~/lib/paths";

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection("posts");
  return posts.map((entry) => ({
    params: { lang: entry.data.lang, slug: postSlug(entry) },
    props: { entry },
  }));
};

interface Props {
  entry: PostEntry;
}

const { entry } = Astro.props as unknown as Props;
const locale = entry.data.lang as Locale;
const otherLocale: Locale = locale === "en" ? "ja" : "en";
const slug = postSlug(entry);
const strings = t(locale);

const otherHref = (await postExists(otherLocale, slug)) ? postUrl(otherLocale, slug) : null;
const xDefault = (await postExists("en", slug)) ? postUrl("en", slug) : undefined;

const { Content } = await render(entry);
const { title, description, pubDate, updatedDate, heroImage, canonicalUrl } = entry.data;
const heroTransitionName = `thumb-post-${slug}`;
---
<BaseLayout
  locale={locale}
  title={title}
  description={description}
  canonical={canonicalUrl}
  alternateUrl={otherHref}
  xDefaultUrl={xDefault}
  ogImage={`/open-graph/${locale}/blog/${slug}.png`}
  article={{ publishedTime: pubDate, modifiedTime: updatedDate }}
>
  <article class="post prose">
    <header class="post__header">
      <h1>{title}</h1>
      <p class="post__meta">
        <span>
          {strings.post.published}{" "}
          <FormattedDate date={pubDate} locale={locale} />
        </span>
        {updatedDate && (
          <span class="post__meta-updated">
            {" · "}
            {strings.post.updated}{" "}
            <FormattedDate date={updatedDate} locale={locale} />
          </span>
        )}
      </p>
    </header>

    {heroImage && (
      <div class="post__hero" style={`view-transition-name: ${heroTransitionName}`}>
        <Image
          src={heroImage}
          alt=""
          widths={[640, 1024, 1536]}
          sizes="(min-width: 48rem) 42rem, 100vw"
          loading="eager"
          decoding="async"
        />
      </div>
    )}

    <div class="post__body">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .post__header {
    margin-bottom: 2rem;
  }

  .post__meta {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-fg-muted);
    margin: 0;
  }

  .post__hero {
    margin: 0 0 2.5rem;
    border-radius: 0.5rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .post__hero :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }
</style>
